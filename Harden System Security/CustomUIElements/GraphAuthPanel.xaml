                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Width="32"
                                Height="32"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                x:Uid="AuthenticatedAccountActionsButton">
                            <Button.Content>
                                <FontIcon Glyph="&#xE712;" FontSize="16"/>
                            </Button.Content>
                            <Button.Flyout>
                                <Flyout>
                                    <Flyout.FlyoutPresenterStyle>
                                        <Style TargetType="FlyoutPresenter">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="MinWidth" Value="0"/>
                                            <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
                                        </Style>
                                    </Flyout.FlyoutPresenterStyle>
                                    <StackPanel Orientation="Vertical"
                                                Spacing="0"
                                                Padding="0"
                                                HorizontalAlignment="Stretch">
                                        <Button x:Uid="SetAccountAsActiveButton"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Click="SetAccountAsActiveButton_Click">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Stretch">
                                                    <AnimatedIcon Height="25" Width="25" Margin="-5,-5,0,-5">
                                                        <AnimatedIcon.Source>
                                                            <animatedvisuals:Select/>
                                                        </AnimatedIcon.Source>
                                                    </AnimatedIcon>
                                                    <TextBlock x:Uid="SetAsActiveTextBlock" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Button x:Uid="RemoveAccountButton"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Click="RemoveAccountButton_Click">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Stretch">
                                                    <AnimatedIcon Height="25" Width="25" Margin="-5,-5,0,-5">
                                                        <AnimatedIcon.Source>
                                                            <animatedvisuals:Logout/>
                                                        </AnimatedIcon.Source>
                                                    </AnimatedIcon>
                                                    <TextBlock x:Uid="RemoveTextBlock" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <Grid Grid.Row="1" ColumnSpacing="6" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Grid.Column="0"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="AccountTenantIDHeaderTextBlock"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyTenantID}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind TenantID, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="AccountIdentifierHeaderTextBlock"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyAccountIdentifier}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind AccountIdentifier, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="ContextHeader"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyAuthContext}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind AuthContext, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
