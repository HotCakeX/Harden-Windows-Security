<Page
      x:Class="HardenSystemSecurity.Pages.WinGetManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:customUI="using:AppControlManager.CustomUIElements"
      xmlns:commonCore="using:CommonCore"
      xmlns:toolkits="using:CommonCore.ToolKits"
      xmlns:vm="using:HardenSystemSecurity.WinGet"
      xmlns:viewModels="using:HardenSystemSecurity.ViewModels">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="BundleSvgIconWellBackgroundBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="BundleSvgIconWellBorderBrush" Color="#E5E5E5" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="BundleSvgIconWellBackgroundBrush" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="BundleSvgIconWellBorderBrush" Color="#DADADA" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <StaticResource x:Key="BundleSvgIconWellBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="BundleSvgIconWellBorderBrush" ResourceKey="SystemColorWindowTextColorBrush" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <Style x:Key="WinGetPackageDetailGridViewItemStyle" TargetType="GridViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
            </Style>
            <Storyboard x:Name="BundleTilesOutStoryboard" Completed="{x:Bind BundleTilesOutStoryboard_Completed}">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesGrid"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.18"
                                      Value="0.62"
                                      KeySpline="0.4,0,1,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.36"
                                      Value="0"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.36"
                                      Value="0.965"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesTransform"
                                           Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.36"
                                      Value="0.965"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesTransform"
                                           Storyboard.TargetProperty="TranslateY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.36"
                                      Value="-22"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Name="BundleTilesInStoryboard">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesGrid"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.18"
                                      Value="0.78"
                                      KeySpline="0,0,0,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.34"
                                      Value="1"
                                      KeySpline="0,0,0,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.965" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.22"
                                      Value="1.012"
                                      KeySpline="0.16,1,0.3,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.38"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesTransform"
                                           Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.965" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.22"
                                      Value="1.012"
                                      KeySpline="0.16,1,0.3,1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.38"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTilesTransform"
                                           Storyboard.TargetProperty="TranslateY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="24" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.38"
                                      Value="0"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Name="BundleOverlayOpenStoryboard">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayGrid"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.08"
                                      Value="1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionLayer"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.58"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.78"
                                      Value="0"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelOneTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.64"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelTwoTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0.06"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.70"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelThreeTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0.12"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.76"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelFourTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0.18"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.82"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayContentTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.98" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.52"
                                      Value="0.98" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.86"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayContentTransform"
                                           Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0.98" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.52"
                                      Value="0.98" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.86"
                                      Value="1"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayContentTransform"
                                           Storyboard.TargetProperty="TranslateY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="26" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.52"
                                      Value="26" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.86"
                                      Value="0"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayContentTransform"
                                           Storyboard.TargetProperty="Rotation">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.86"
                                      Value="0" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayToolbar"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.50"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.82"
                                      Value="1"
                                      KeySpline="0,0,0,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayToolbarTransform"
                                           Storyboard.TargetProperty="TranslateY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="22" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.50"
                                      Value="22" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.86"
                                      Value="0"
                                      KeySpline="0.16,1,0.3,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayAppsGrid"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.58"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.96"
                                      Value="1"
                                      KeySpline="0,0,0,1" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Name="BundleOverlayCloseStoryboard" Completed="{x:Bind BundleOverlayCloseStoryboard_Completed}">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayGrid"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.40"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.58"
                                      Value="0"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionLayer"
                                           Storyboard.TargetProperty="Opacity">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.46"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.58"
                                      Value="0" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelOneTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.42"
                                      Value="0"
                                      KeySpline="0.7,0,0.84,0" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelTwoTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0.04"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.46"
                                      Value="0"
                                      KeySpline="0.7,0,0.84,0" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelThreeTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0.08"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.50"
                                      Value="0"
                                      KeySpline="0.7,0,0.84,0" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleTransitionPanelFourTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0.12"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.54"
                                      Value="0"
                                      KeySpline="0.7,0,0.84,0" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayContentTransform"
                                           Storyboard.TargetProperty="ScaleX">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.28"
                                      Value="0.98"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayContentTransform"
                                           Storyboard.TargetProperty="ScaleY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="1" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.28"
                                      Value="0.98"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BundleOverlayContentTransform"
                                           Storyboard.TargetProperty="TranslateY">
                    <SplineDoubleKeyFrame KeyTime="0:0:0"
                                      Value="0" />
                    <SplineDoubleKeyFrame KeyTime="0:0:0.28"
                                      Value="18"
                                      KeySpline="0.4,0,1,1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimation Storyboard.TargetName="BundleOverlayToolbar"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.18" />
                <DoubleAnimation Storyboard.TargetName="BundleOverlayAppsGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.18" />
            </Storyboard>
            <DataTemplate x:Key="WinGetPackageDetailTemplate" x:DataType="vm:WinGetPackageDetailItem">
                <Border Width="320"
                    Height="92"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="12,0,0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#DA4453" Offset="0" />
                                    <GradientStop Color="#89216B" Offset="0.7" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Grid Grid.Column="1" Padding="10,8" RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                       Text="{x:Bind Label}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                                <Button x:Uid="WinGetCopyDetailValueButton" Grid.Column="1"
                                    Width="30"
                                    Height="30"
                                    Padding="0"
                                    Tag="{x:Bind Value}"
                                    VerticalAlignment="Top"
                                    Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.CopyPackageDetail_Click}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                                </Button>
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Visible"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollMode="Auto"
                                      IsVerticalRailEnabled="True"
                                      HorizontalScrollMode="Disabled">
                                <TextBlock Text="{x:Bind Value}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True" />
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="WinGetBundlePreviewIconTemplate" x:DataType="viewModels:WinGetPackageBundlePackage">
                <Grid Width="58" Height="58">
                    <Border CornerRadius="14"
                            Background="{ThemeResource BundleSvgIconWellBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource BundleSvgIconWellBorderBrush}"
                            Visibility="{x:Bind IconBackgroundVisibility}" />
                    <Image Width="54" Height="54" Stretch="Uniform">
                        <Image.Source>
                            <SvgImageSource UriSource="{x:Bind IconUri}" />
                        </Image.Source>
                    </Image>
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="WinGetBundleTileTemplate" x:DataType="viewModels:WinGetPackageBundle">
                <StackPanel Width="250" Spacing="12" HorizontalAlignment="Center">
                    <Border Height="190"
                            CornerRadius="14"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <ItemsControl ItemsSource="{x:Bind PreviewPackages}"
                                      ItemTemplate="{StaticResource WinGetBundlePreviewIconTemplate}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <toolkits:WrapPanel Width="132"
                                                        Orientation="Horizontal"
                                                        HorizontalSpacing="16"
                                                        VerticalSpacing="16" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                    <TextBlock Text="{x:Bind Name}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="WrapWholeWords"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                </StackPanel>
            </DataTemplate>
            <DataTemplate x:Key="WinGetBundleAppTemplate" x:DataType="viewModels:WinGetPackageBundlePackage">
                <Button x:Uid="WinGetBundleAppActionsButton" Width="158"
                    MinHeight="166"
                    Padding="8"
                    HorizontalAlignment="Center"
                    Tag="{x:Bind}"
                    IsEnabled="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.BundlesUIElementsAreEnabled, Mode=OneWay}"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    AutomationProperties.Name="{x:Bind DisplayName}">
                    <StackPanel Spacing="8"
                            HorizontalAlignment="Center">
                        <Grid Width="66" Height="66">
                            <Border CornerRadius="18"
                                    Background="{ThemeResource BundleSvgIconWellBackgroundBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource BundleSvgIconWellBorderBrush}"
                                    Visibility="{x:Bind IconBackgroundVisibility}" />
                            <Image Width="62" Height="62" Stretch="Uniform">
                                <Image.Source>
                                    <SvgImageSource UriSource="{x:Bind IconUri}" />
                                </Image.Source>
                            </Image>
                        </Grid>
                        <TextBlock Text="{x:Bind DisplayName}"
                               TextAlignment="Center"
                               TextWrapping="WrapWholeWords"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               Style="{ThemeResource BodyTextBlockStyle}" />
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <SplitMenuFlyoutItem x:Uid="WinGetInstallOrUpdateMenuFlyoutItem"
                                             Tag="{x:Bind}"
                                             Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.InstallBundlePackage_Click}">
                                <SplitMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEDAB;" />
                                </SplitMenuFlyoutItem.Icon>
                                <SplitMenuFlyoutItem x:Uid="WinGetSilentMenuFlyoutItem"
                                                 Tag="{x:Bind}"
                                                 Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.InstallBundlePackageSilent_Click}">
                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.InstallBundlePackageSilentUser_Click}" />
                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.InstallBundlePackageSilentMachine_Click}" />
                                </SplitMenuFlyoutItem>
                                <SplitMenuFlyoutItem x:Uid="WinGetInteractiveMenuFlyoutItem"
                                                 Tag="{x:Bind}"
                                                 Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.InstallBundlePackageInteractive_Click}">
                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.InstallBundlePackageInteractiveUser_Click}" />
                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.InstallBundlePackageInteractiveMachine_Click}" />
                                </SplitMenuFlyoutItem>
                            </SplitMenuFlyoutItem>
                            <SplitMenuFlyoutItem x:Uid="UninstallText"
                                             Tag="{x:Bind}"
                                             Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UninstallBundlePackage_Click}">
                                <SplitMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEC91;" />
                                </SplitMenuFlyoutItem.Icon>
                                <SplitMenuFlyoutItem x:Uid="WinGetSilentMenuFlyoutItem"
                                                 Tag="{x:Bind}"
                                                 Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UninstallBundlePackageSilent_Click}">
                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UninstallBundlePackageSilentUser_Click}" />
                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UninstallBundlePackageSilentMachine_Click}" />
                                </SplitMenuFlyoutItem>
                                <SplitMenuFlyoutItem x:Uid="WinGetInteractiveMenuFlyoutItem"
                                                 Tag="{x:Bind}"
                                                 Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UninstallBundlePackageInteractive_Click}">
                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UninstallBundlePackageInteractiveUser_Click}" />
                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                Tag="{x:Bind}"
                                                IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UninstallBundlePackageInteractiveMachine_Click}" />
                                </SplitMenuFlyoutItem>
                            </SplitMenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </DataTemplate>
            <DataTemplate x:Key="WinGetPackageSearchTemplate" x:DataType="vm:WinGetPackageSearchResult">
                <Border CornerRadius="18"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Margin="4,2,4,10"
                    HorizontalAlignment="Stretch">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="18,18,0,0" Padding="14,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF243B55" Offset="0" />
                                    <GradientStop Color="#FF141E30" Offset="0.45" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                    Width="40"
                                    Height="40"
                                    CornerRadius="12"
                                    VerticalAlignment="Top"
                                    Background="#22FFFFFF"
                                    BorderThickness="1"
                                    BorderBrush="#33FFFFFF">
                                    <FontIcon Glyph="&#xE74C;"
                                          FontSize="18"
                                          Foreground="White" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                           Style="{ThemeResource SubtitleTextBlockStyle}"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           TextWrapping="Wrap" />
                                    <TextBlock Text="{x:Bind Id, Mode=OneWay}"
                                           FontFamily="Consolas"
