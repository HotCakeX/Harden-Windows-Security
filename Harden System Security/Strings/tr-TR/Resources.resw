  <data name="LockScreenPageTitle" xml:space="preserve">
    <value>İşletim sisteminin Kilit Ekranını olası istismarlara karşı güçlendirin ve cihaz kilitlendiğinde yetkisiz kişilerin eline geçen bilgi miktarını azaltın.</value>
  </data>
  <data name="MiscellaneousConfigsPageTitle" xml:space="preserve">
