<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AppControlManager.Pages.Analysis.EventLogs"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    xmlns:VMs="using:AppControlManager.ViewModels"
    xmlns:Analysis="using:AppControlManager.Analysis"
    xmlns:CustomUIElements="using:AppControlManager.CustomUIElements">

    <Page.Resources>
        <ThemeShadow x:Key="PopoutShadow" />

        <DataTemplate x:Key="AnalysisItemTemplate" x:DataType="Analysis:AnalysisResultItem">
            <Grid ColumnSpacing="8" Background="Transparent" Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Color Picker -->
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" Fill="{x:Bind ColorBrush, Mode=OneWay}" Stroke="{ThemeResource CardStrokeColorDefaultBrush}" StrokeThickness="1"/>
                    <Button.Flyout>
                        <Flyout>
                            <ColorPicker Color="{x:Bind ItemColor, Mode=TwoWay}"
                                         ColorSpectrumShape="Ring"
                                         IsMoreButtonVisible="True"
                                         IsColorSliderVisible="True"
                                         IsAlphaEnabled="False"
                                         IsColorChannelTextInputVisible="False"
                                         IsHexInputVisible="True"/>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Base Item (Truncated) & Popout handled exclusively here -->
                <Grid Grid.Column="1"
                      PointerEntered="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.AnalysisItem_PointerEntered}"
                      PointerExited="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.AnalysisItem_PointerExited}"
                      Background="Transparent">
                    <Border x:Name="BaseBorder" Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                            <Border Grid.Column="1" Background="{ThemeResource SystemAccentColor}" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Count}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Popout Item (Full Text) -->
                    <Popup x:Name="HoverPopup" IsLightDismissEnabled="False">
                        <Popup.ChildTransitions>
                            <TransitionCollection>
                                <PopupThemeTransition />
                            </TransitionCollection>
                        </Popup.ChildTransitions>
                        <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="10,6"
                                Shadow="{StaticResource PopoutShadow}"
                                Translation="0,0,32"
                                PointerExited="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.PopupBorder_PointerExited}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Always binds to the full unformatted text string for hovering visibility -->
                                <TextBlock Grid.Column="0" Text="{x:Bind Name}" TextWrapping="WrapWholeWords" MaxWidth="320" VerticalAlignment="Center" />

                                <Border Grid.Column="1" Background="{ThemeResource SystemAccentColor}" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Count}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" FontSize="12" />
                                </Border>

                                <Button Grid.Column="2" ToolTipService.ToolTip="Copy" Click="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.CopyItemText_Click}" Tag="{x:Bind Name}" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="4">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                </Button>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AnalysisCategoryTemplate" x:DataType="Analysis:AnalysisCategory">
            <Border CornerRadius="8" Width="340" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                <StackPanel Spacing="15">

                    <CCToolKit:WrapPanel Orientation="Horizontal" HorizontalSpacing="10" VerticalSpacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,10,0">
                            <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="16" />
                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center">
                            <RadioButton IsChecked="{x:Bind IsPieChartVisible, Mode=TwoWay}" Content="Pie" MinWidth="50" Margin="8,4,4,4" Background="Transparent" BorderThickness="0" />
                            <RadioButton IsChecked="{x:Bind IsBarChartVisible, Mode=TwoWay}" Content="Bar" MinWidth="50" Margin="4,4,8,4" Background="Transparent" BorderThickness="0" />
                        </StackPanel>
                    </CCToolKit:WrapPanel>

                    <Grid Height="150" Margin="0,10,0,10">
                        <!-- Dynamic Pie Chart -->
                        <Grid Visibility="{x:Bind PieChartVisibility, Mode=OneWay}" Width="150" Height="150" HorizontalAlignment="Center">
                            <ItemsControl ItemsSource="{x:Bind PieSlices, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="Analysis:PieSliceData">
                                        <Grid PointerEntered="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.PieSlice_PointerEntered}"
                                              PointerExited="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.PieSlice_PointerExited}"
                                              Tag="{x:Bind}">
                                            <Path Data="{x:Bind PathData}" Fill="{x:Bind Fill}" Stroke="{ThemeResource LayerFillColorDefaultBrush}" StrokeThickness="2" StrokeLineJoin="Round" ToolTipService.ToolTip="{x:Bind Tooltip}" />
                                            <TextBlock Text="{x:Bind PercentageText}" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Top" IsHitTestVisible="False">
                                                <TextBlock.RenderTransform>
                                                    <TranslateTransform X="{x:Bind LabelX}" Y="{x:Bind LabelY}" />
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- Dynamic Bar Chart -->
                        <Grid Visibility="{x:Bind BarChartVisibility, Mode=OneWay}" HorizontalAlignment="Center">
                            <ItemsControl ItemsSource="{x:Bind ColumnBars, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="15" Height="140" VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="Analysis:ColumnBarData">
                                        <Grid VerticalAlignment="Bottom">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{x:Bind PercentageText}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                            <Border Grid.Row="1" Width="30" Height="{x:Bind Height}" CornerRadius="4,4,0,0" Background="{x:Bind Fill}" VerticalAlignment="Bottom" ToolTipService.ToolTip="{x:Bind Tooltip}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>

                    <!-- Items List -->
                    <ItemsControl ItemsSource="{x:Bind Items, Mode=OneWay}" ItemTemplate="{StaticResource AnalysisItemTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Time range control area. -->
        <Border Grid.Row="0" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="16">
            <CCToolKit:WrapPanel Orientation="Horizontal" HorizontalSpacing="12" VerticalSpacing="8">
                <StackPanel Spacing="4" MinWidth="260">
                    <TextBlock Text="Time range" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold" />
                    <ComboBox MinWidth="260"
                              ItemsSource="{x:Bind ViewModel.AnalysisResults.Analysis_TimeRangeOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.AnalysisResults.Analysis_SelectedTimeRange, Mode=TwoWay}"
                              SelectionChanged="{x:Bind ViewModel.AnalysisResults.TimeRangeComboBox_SelectionChanged}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom"
                            Visibility="{x:Bind ViewModel.AnalysisResults.Analysis_RecalculationProgressVisibility, Mode=OneWay}">
                    <ProgressRing Width="22" Height="22" IsActive="{x:Bind ViewModel.AnalysisResults.Analysis_IsRecalculating, Mode=OneWay}" IsIndeterminate="True" />
                    <TextBlock Text="Recalculating analysis" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button Click="{x:Bind ExportPageToPdf_Click}" Padding="12,6" VerticalAlignment="Bottom" ToolTipService.ToolTip="Export the analysis page to PDF">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEA90;" FontSize="14" />
                        <TextBlock Text="Export PDF" />
                    </StackPanel>
                </Button>
                <StackPanel x:Name="PdfExportProgressPanel" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" Visibility="Collapsed">
                    <ProgressRing x:Name="PdfExportProgressRing" Width="22" Height="22" IsIndeterminate="True" />
                    <TextBlock Text="Generating PDF" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </CCToolKit:WrapPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="0,10,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Opacity="{x:Bind ViewModel.AnalysisResults.Analysis_ContentOpacity, Mode=OneWay}"
                      IsHitTestVisible="{x:Bind ViewModel.AnalysisResults.Analysis_ContentIsHitTestVisible, Mode=OneWay}">
            <StackPanel x:Name="AnalysisContentPanel" Spacing="20">

                <!-- Data Summary Section -->
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8F3;" Foreground="{ThemeResource SystemAccentColor}" FontSize="18" />
                            <TextBlock x:Uid="DataSummary" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_SummaryText, Mode=OneWay}" IsTextSelectionEnabled="True" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Actionable Recommendations Section -->
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE81E;" Foreground="{ThemeResource SystemAccentColor}" FontSize="18" />
                            <TextBlock x:Uid="RecommendedActions" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.AnalysisResults.Analysis_ActionableRecommendations, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Grid ColumnSpacing="10" Margin="0,4,0,4" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xEA3A;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind}" TextWrapping="Wrap" IsTextSelectionEnabled="True" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Stretch" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Top Level Outcomes Cards -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xEA39;" Foreground="Red" FontSize="20" />
                                <TextBlock x:Uid="TotalBlockedItems" Style="{StaticResource SubtitleTextBlockStyle}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_TotalBlocked, Mode=OneWay}" Style="{StaticResource HeaderTextBlockStyle}" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE73E;" Foreground="LimeGreen" FontSize="20" />
                                <TextBlock x:Uid="TotalAllowedOrAuditedItems" Style="{StaticResource SubtitleTextBlockStyle}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_TotalAllowed, Mode=OneWay}" Style="{StaticResource HeaderTextBlockStyle}" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Color Palettes -->
                <StackPanel Spacing="10">
                    <TextBlock x:Uid="ColorPalettes" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled">
                        <ItemsControl ItemsSource="{x:Bind Analysis:FileIdentityAnalysis.AvailablePalettes}" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="Analysis:ColorPalette">
                                    <Button Click="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.PaletteButton_Click}" Tag="{x:Bind}" Padding="10" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="0" Background="Transparent">
                                                <Border Width="20" Height="20" Background="{x:Bind Brush1}" CornerRadius="4,0,0,4" />
                                                <Border Width="20" Height="20" Background="{x:Bind Brush2}" />
                                                <Border Width="20" Height="20" Background="{x:Bind Brush3}" CornerRadius="0,4,4,0" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Name}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- Visualization Charts Section -->
                <StackPanel Spacing="15">
                    <TextBlock x:Uid="DataVisualizations" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    <StackPanel Spacing="20" HorizontalAlignment="Stretch">

                        <!-- Interactive Combined Events Trend Chart -->
                        <Border CornerRadius="8" HorizontalAlignment="Stretch" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                            <StackPanel Spacing="20">
                                <Grid>
                                    <TextBlock Text="Events Trend" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="4" Click="{x:Bind EventsTrendChart.ExportCurrentViewToSvg_Click}" ToolTipService.ToolTip="Download SVG">
                                        <FontIcon Glyph="&#xE896;" FontSize="14" />
                                    </Button>
                                </Grid>

                                <CustomUIElements:InteractiveLineChart
                                    x:Name="EventsTrendChart"
                                    MinHeight="360"
                                    ChartStateKey="EventLogs"  
                                    Series1Name="Blocked"
                                    Series2Name="Allowed"
                                    SelectedRangeMinimum="{x:Bind ViewModel.AnalysisResults.Analysis_CustomRangeStartTicks, Mode=OneWay}"
                                    SelectedRangeMaximum="{x:Bind ViewModel.AnalysisResults.Analysis_CustomRangeEndTicks, Mode=OneWay}"
                                    RangeSelectionChanged="{x:Bind ViewModel.AnalysisResults.EventsTrendChart_RangeSelectionChanged}"
                                    Series1Items="{x:Bind ViewModel.AnalysisResults.BlockedTrendPoints}"
                                    Series2Items="{x:Bind ViewModel.AnalysisResults.AllowedTrendPoints}" />
                            </StackPanel>
                        </Border>
                        <CCToolKit:WrapPanel Orientation="Horizontal" HorizontalSpacing="20" VerticalSpacing="20" HorizontalAlignment="Center">
                            <!-- Pie Chart (Allowed vs Blocked) -->
                            <Border CornerRadius="8" MinWidth="340" HorizontalAlignment="Center" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                                <StackPanel Spacing="20">
                                    <Grid>
                                        <TextBlock x:Uid="DistributionOverview" Style="{StaticResource BaseTextBlockStyle}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="4" Tag="Pie" Click="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.ExportChart_Click}" ToolTipService.ToolTip="Download SVG">
                                            <FontIcon Glyph="&#xE896;" FontSize="14" />
                                        </Button>
                                    </Grid>

                                    <Grid Width="200" Height="200" HorizontalAlignment="Center">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.AnalysisResults.Chart_PieSlices, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Grid />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="Analysis:PieSliceData">
                                                    <Grid PointerEntered="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.PieSlice_PointerEntered}" PointerExited="{x:Bind VMs:ViewModelProvider.EventLogsPolicyCreationVM.AnalysisResults.PieSlice_PointerExited}" Tag="{x:Bind}">
                                                        <Path Data="{x:Bind PathData}" Fill="{x:Bind Fill}" Stroke="{ThemeResource LayerFillColorDefaultBrush}" StrokeThickness="2" StrokeLineJoin="Round" ToolTipService.ToolTip="{x:Bind Tooltip}">
                                                            <Path.Transitions>
                                                                <TransitionCollection>
                                                                    <EntranceThemeTransition />
                                                                </TransitionCollection>
                                                            </Path.Transitions>
                                                        </Path>

                                                        <!-- Slice Percentage Label -->
                                                        <TextBlock Text="{x:Bind PercentageText}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Left"
                                                                   VerticalAlignment="Top"
                                                                   IsHitTestVisible="False">
                                                            <TextBlock.RenderTransform>
                                                                <TranslateTransform X="{x:Bind LabelX}" Y="{x:Bind LabelY}" />
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <!-- Pie Legend -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Ellipse Width="10" Height="10" Fill="LimeGreen" />
                                            <TextBlock x:Uid="Allowed" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Ellipse Width="10" Height="10" Fill="OrangeRed" />
                                            <TextBlock x:Uid="Blocked" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <!-- Temporal Polar Chart -->
                            <Border CornerRadius="8" MinWidth="760" HorizontalAlignment="Stretch" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="20">
                                <CustomUIElements:TemporalPolarChart
                                    MinHeight="360"
                                    Series1Name="Blocked"
                                    Series2Name="Allowed"
                                    Series1Items="{x:Bind ViewModel.AnalysisResults.BlockedTrendPoints, Mode=OneWay}"
                                    Series2Items="{x:Bind ViewModel.AnalysisResults.AllowedTrendPoints, Mode=OneWay}"
                                    SelectedRangeMinimum="{x:Bind ViewModel.AnalysisResults.Analysis_CustomRangeStartTicks, Mode=OneWay}"
                                    SelectedRangeMaximum="{x:Bind ViewModel.AnalysisResults.Analysis_CustomRangeEndTicks, Mode=OneWay}" />
                            </Border>
                        </CCToolKit:WrapPanel>

                    </StackPanel>
                </StackPanel>
                <!-- Global Security Metrics (All Events) -->
                <StackPanel Spacing="15">
                    <TextBlock x:Uid="GlobalMetrics" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    <CCToolKit:WrapPanel HorizontalSpacing="15" VerticalSpacing="15" Orientation="Horizontal">

                        <Border CornerRadius="8" MinWidth="220" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Signed Files" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_Global_TotalSigned, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" MinWidth="220" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Unsigned Files" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_Global_TotalUnsigned, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" MinWidth="220" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="User-Writeable Locations" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" ToolTipService.ToolTip="Originating from paths like Downloads or AppData." />
                                <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_Global_TotalUserWriteable, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" MinWidth="220" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Signing Level Mismatches" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_Global_TotalSigningLevelMismatches, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" MinWidth="220" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="ECC Signed Files" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_Global_TotalECCSigned, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8" MinWidth="220" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="WHQL Certified" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.AnalysisResults.Analysis_Global_TotalWHQL, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                            </StackPanel>
                        </Border>

                    </CCToolKit:WrapPanel>
                </StackPanel>

                <!-- Blocked Insights Section -->
                <StackPanel Spacing="15">
                    <TextBlock Text="Insights: Blocked Events" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="Red" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.AnalysisResults.BlockedCategories, Mode=OneWay}" ItemTemplate="{StaticResource AnalysisCategoryTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <CCToolKit:WrapPanel HorizontalSpacing="20" VerticalSpacing="20" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>

                <!-- Allowed / Audited Insights Section -->
                <StackPanel Spacing="15">
                    <TextBlock Text="Insights: Allowed / Audited Events" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="LimeGreen" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.AnalysisResults.AllowedCategories, Mode=OneWay}" ItemTemplate="{StaticResource AnalysisCategoryTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <CCToolKit:WrapPanel HorizontalSpacing="20" VerticalSpacing="20" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
