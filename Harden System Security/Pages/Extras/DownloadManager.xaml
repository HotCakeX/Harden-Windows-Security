<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HardenSystemSecurity.Pages.Extras.DownloadManager"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommonCore="using:CommonCore"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    xmlns:vm="using:HardenSystemSecurity.ViewModels"
    KeyboardAcceleratorPlacementMode="Hidden"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="V"
                             Modifiers="Control"
                             Invoked="{x:Bind ViewModel.PasteLinksKeyboardAccelerator_Invoked}" />
    </Page.KeyboardAccelerators>

    <Grid AllowDrop="{x:Bind CommonCore:ViewModelBase.IsNotElevated}"
          DragOver="{x:Bind ViewModel.DownloadManagerGrid_DragOver}"
          Drop="{x:Bind ViewModel.DownloadManagerGrid_Drop}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customUI:InfoBarV2 Grid.Row="0"                            
                            IsOpen="{x:Bind ViewModel.MainInfoBar.IsOpen, Mode=TwoWay}"
                            Message="{x:Bind ViewModel.MainInfoBar.Message, Mode=OneWay}"
                            Severity="{x:Bind ViewModel.MainInfoBar.Severity, Mode=OneWay}"
                            IsClosable="{x:Bind ViewModel.MainInfoBar.IsClosable, Mode=OneWay}" />

        <CommandBar DefaultLabelPosition="Right"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"                    
                    OverflowButtonVisibility="Auto">

            <AppBarElementContainer VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,5,0">
                <TextBox x:Uid="SearchBoxTextBox"
                         MaxWidth="150"
                         VerticalAlignment="Center"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </AppBarElementContainer>

            <AppBarButton Click="{x:Bind ViewModel.ShowAddLinksDialogAsync}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          x:Uid="AddLinksAppBarButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarButton VerticalAlignment="Center"
                          Label="Sort"
                          HorizontalAlignment="Center"
                          ToolTipService.ToolTip="{x:Bind ViewModel.ActiveSortToolTip, Mode=OneWay}"
                          AutomationProperties.Name="{x:Bind ViewModel.ActiveSortToolTip, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8CB;" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="Name"
                                        Click="{x:Bind ViewModel.SortByNameMenuFlyoutItem_Click}" />
                        <MenuFlyoutItem Text="Size"
                                        Click="{x:Bind ViewModel.SortBySizeMenuFlyoutItem_Click}" />
                        <MenuFlyoutItem Text="Date added"
                                        Click="{x:Bind ViewModel.SortByDateAddedMenuFlyoutItem_Click}" />
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>

            <AppBarButton Click="{x:Bind ViewModel.OpenSettingsPageAsync}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          x:Uid="SettingsAppBarButton">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarElementContainer VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="5">
                <DropDownButton ToolTipService.ToolTip="{x:Bind ViewModel.ActiveSpeedPresetToolTip, Mode=OneWay}">
                    <DropDownButton.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{x:Bind ViewModel.ActiveSpeedPresetGlyph, Mode=OneWay}"
                                      Foreground="{x:Bind ViewModel.ActiveSpeedPresetBrush, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.ActiveSpeedPresetText, Mode=OneWay}"
                                       Foreground="{x:Bind ViewModel.ActiveSpeedPresetBrush, Mode=OneWay}" />
                        </StackPanel>
                    </DropDownButton.Content>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem x:Uid="Slow" Click="{x:Bind ViewModel.ApplySlowPresetMenuFlyoutItem_Click}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEC48;" Foreground="IndianRed" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="Medium" Click="{x:Bind ViewModel.ApplyMediumPresetMenuFlyoutItem_Click}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEC49;" Foreground="DarkOrange" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="Full" Click="{x:Bind ViewModel.ApplyFullPresetMenuFlyoutItem_Click}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEC4A;" Foreground="SpringGreen" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                    <DropDownButton.ContextFlyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem x:Uid="AdjustDownloadPresetLimits"
                                            Click="{x:Bind ViewModel.OpenPresetLimitsSettingsMenuFlyoutItem_Click}" />
                        </MenuFlyout>
                    </DropDownButton.ContextFlyout>
                </DropDownButton>

            </AppBarElementContainer>

            <AppBarElementContainer VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                <!-- Total chip -->
                <Border CornerRadius="8"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Padding="10,6"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8A9;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock VerticalAlignment="Center">
                            <Run x:Uid="TotalText" />
                            <Run Text="{x:Bind ViewModel.FilteredDownloadItems.Count, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </AppBarElementContainer>

            <AppBarButton VerticalAlignment="Center"
                          Label="Select all"
                          HorizontalAlignment="Center"
                          Click="SelectAllDownloadsAppBarButton_Click"
                          IsEnabled="{x:Bind ViewModel.CanSelectAllDownloads, Mode=OneWay}"
                          ToolTipService.ToolTip="Select all downloads"
                          AutomationProperties.Name="Select all downloads">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="SelectAll" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton VerticalAlignment="Center"
                          Label="Deselect all"
                          HorizontalAlignment="Center"
                          Click="DeselectAllDownloadsAppBarButton_Click"
                          IsEnabled="{x:Bind ViewModel.CanDeselectAllDownloads, Mode=OneWay}"
                          ToolTipService.ToolTip="Deselect all downloads"
                          AutomationProperties.Name="Deselect all downloads">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8E6;" />
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarButton x:Uid="PauseAppBarButton"
                          Visibility="{x:Bind ViewModel.SelectionActionsVisibility, Mode=OneWay}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Click="{x:Bind ViewModel.PauseSelectedDownloadsAppBarButton_Click}"
                          IsEnabled="{x:Bind ViewModel.CanPauseSelectedDownloads, Mode=OneWay}">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Pause" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Uid="ResumeAppBarButton"
                          Visibility="{x:Bind ViewModel.SelectionActionsVisibility, Mode=OneWay}"
                          Click="{x:Bind ViewModel.ResumeSelectedDownloadsAppBarButton_Click}"
                          IsEnabled="{x:Bind ViewModel.CanResumeSelectedDownloads, Mode=OneWay}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Play" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator Visibility="{x:Bind ViewModel.SelectionActionsVisibility, Mode=OneWay}" />
            <AppBarButton x:Uid="DeleteAppBarButton"
                          Visibility="{x:Bind ViewModel.SelectionActionsVisibility, Mode=OneWay}"
                          Click="{x:Bind ViewModel.DeleteSelectedDownloadsAppBarButton_Click}"
                          IsEnabled="{x:Bind ViewModel.CanDeleteSelectedDownloads, Mode=OneWay}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Delete" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Uid="RemoveFromListAppBarButton"
                          Visibility="{x:Bind ViewModel.SelectionActionsVisibility, Mode=OneWay}"
                          Click="{x:Bind ViewModel.RemoveSelectedDownloadsAppBarButton_Click}"
                          IsEnabled="{x:Bind ViewModel.CanRemoveSelectedDownloads, Mode=OneWay}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Remove" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <Grid Grid.Row="2">
            <ListView x:Name="DownloadItemsListView"
                      ItemsSource="{x:Bind ViewModel.FilteredDownloadItems, Mode=OneWay}"
                      SelectionMode="Multiple"
                      CanDragItems="True"
                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                      ScrollViewer.IsVerticalRailEnabled="True"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      DragItemsStarting="{x:Bind ViewModel.DownloadItemsListView_DragItemsStarting}"
                      SelectionChanged="{x:Bind ViewModel.DownloadItemsListView_SelectionChanged}">
                <ListView.Resources>
                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent"/>
                </ListView.Resources>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DownloadManagerItem">
                        <Border Padding="5,8,5,8"
                                Margin="0,0,0,8"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                HorizontalAlignment="Stretch"
                                Tag="{x:Bind}"
                                DoubleTapped="{x:Bind vm:ViewModelProvider.DownloadManagerVM.DownloadItemBorder_DoubleTapped}">
                            <Grid ColumnSpacing="12"
                                  HorizontalAlignment="Stretch">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- File Preview Section -->
                                <Border Width="132"
                                        Grid.Column="0"
                                        Height="120"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        RenderTransformOrigin="0.5,0.5"
                                        Tag="{x:Bind}"
                                        PointerEntered="{x:Bind vm:ViewModelProvider.DownloadManagerVM.PreviewSurface_PointerEntered}"
                                        PointerExited="{x:Bind vm:ViewModelProvider.DownloadManagerVM.PreviewSurface_PointerExited}">
                                    <Border.RenderTransform>
                                        <CompositeTransform />
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Image Source="{x:Bind PreviewImageSource, Mode=OneWay}"
                                               Stretch="{x:Bind PreviewImageStretch, Mode=OneWay}"
                                               Margin="{x:Bind PreviewImageMargin, Mode=OneWay}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="{x:Bind PreviewVisibility, Mode=OneWay}" />
                                        <MediaPlayerElement x:Name="HoverPreviewPlayer"
                                                            x:Load="{x:Bind CanHoverPlayVideoPreview, Mode=OneWay}"
                                                            Source="{x:Bind HoverVideoPreviewSource, Mode=OneWay}"
                                                            Stretch="UniformToFill"
                                                            AutoPlay="True"                                                            
                                                            AreTransportControlsEnabled="False"
                                                            IsHitTestVisible="False"
                                                            Loaded="{x:Bind vm:DownloadManagerVM.HoverPreviewPlayer_Loaded}"                                                          
                                                            Visibility="{x:Bind HoverVideoPreviewVisibility, Mode=OneWay}" />
                                        <Border VerticalAlignment="Bottom"
                                                Margin="4"
                                                Padding="5"
                                                HorizontalAlignment="Center"
                                                CornerRadius="10"
                                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                Visibility="{x:Bind VideoPreviewHintVisibility, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE768;" FontSize="12" />
                                                <TextBlock Text="Hover to preview" FontSize="11"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{x:Bind PreviewPlaceholderText, Mode=OneWay}"
                                                   Visibility="{x:Bind PreviewPlaceholderVisibility, Mode=OneWay}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Margin="8" />
                                    </Grid>
                                </Border>

                                <!-- Column 1, containing the rest of the controls besides preview section -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Vertical"
                                            Spacing="8"
                                            HorizontalAlignment="Stretch">

                                    <!-- Row 0 -->
                                    <CCToolKit:WrapPanel Orientation="Horizontal"
                                                         HorizontalSpacing="8"
                                                         VerticalSpacing="8">

                                        <Button Tag="{x:Bind}"
                                                Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.OpenContainingFolderButton_Click}"
                                                ToolTipService.ToolTip="Open saved folder">
                                            <FontIcon Glyph="&#xE8B7;" />
                                        </Button>

                                        <Button Tag="{x:Bind}"
                                                Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.PauseOrResumeButton_Click}"
                                                IsEnabled="{x:Bind CanPauseOrResumeDownload, Mode=OneWay}"
                                                ToolTipService.ToolTip="{x:Bind PauseOrResumeToolTip, Mode=OneWay}">
                                            <FontIcon Glyph="{x:Bind PauseOrResumeGlyph, Mode=OneWay}" />
                                        </Button>

                                        <Button ToolTipService.ToolTip="More actions">
                                            <FontIcon Glyph="&#xE712;" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Open"
                                                                    Tag="{x:Bind}"
                                                                    Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.OpenDownloadedFileMenuItem_Click}"
                                                                    IsEnabled="{x:Bind IsFileAvailable, Mode=OneWay}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE7AC;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Delete file"
                                                                    Tag="{x:Bind}"
                                                                    Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.DeleteDownloadedFileMenuItem_Click}">
                                                        <MenuFlyoutItem.Icon>
                                                            <SymbolIcon Symbol="Delete" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Copy download link"
                                                                    Tag="{x:Bind}"
                                                                    Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.CopyDownloadLinkMenuItem_Click}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE8C8;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem x:Uid="ChangeDownloadLinkMenuFlyoutItem"
                                                                    Tag="{x:Bind}"
                                                                    Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.ChangeDownloadLinkMenuItem_Click}"
                                                                    IsEnabled="{x:Bind CanChangeDownloadLink, Mode=OneWay}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE8AC;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSubItem Text="Get Hash"
                                                                       IsEnabled="{x:Bind IsFileAvailable, Mode=OneWay}">
                                                        <MenuFlyoutSubItem.Icon>
                                                            <FontIcon Glyph="&#xEF3D;" />
                                                        </MenuFlyoutSubItem.Icon>
                                                        <MenuFlyoutItem Text="SHA-2 256"
                                                                        Tag="{x:Bind}"
                                                                        Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.ShowSha2256MenuItem_Click}" />
                                                        <MenuFlyoutItem Text="SHA-2 512"
                                                                        Tag="{x:Bind}"
                                                                        Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.ShowSha2512MenuItem_Click}" />
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="SHA3 256"
                                                                        Tag="{x:Bind}"
                                                                        Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.ShowSha3256MenuItem_Click}" />
                                                        <MenuFlyoutItem Text="SHA3 384"
                                                                        Tag="{x:Bind}"
                                                                        Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.ShowSha3384MenuItem_Click}" />
                                                        <MenuFlyoutItem Text="SHA3 512"
                                                                        Tag="{x:Bind}"
                                                                        Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.ShowSha3512MenuItem_Click}" />
                                                    </MenuFlyoutSubItem>
                                                    <MenuFlyoutItem Text="Remove item from list"
                                                                    Tag="{x:Bind}"
                                                                    Click="{x:Bind vm:ViewModelProvider.DownloadManagerVM.RemoveFromListMenuItem_Click}">
                                                        <MenuFlyoutItem.Icon>
                                                            <SymbolIcon Symbol="Remove" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>

                                    </CCToolKit:WrapPanel>

                                    <!-- Row 1 -->
                                    <TextBlock Text="{x:Bind StatusSummary, Mode=OneWay}"
                                               Foreground="{x:Bind StatusForeground, Mode=OneWay}"
                                               TextWrapping="WrapWholeWords" />

                                    <!-- Row 2 -->
                                    <ProgressBar Visibility="{x:Bind ProgressVisibility, Mode=OneWay}"
                                                 Value="{x:Bind ProgressValue, Mode=OneWay}"
                                                 IsIndeterminate="{x:Bind IsProgressIndeterminate, Mode=OneWay}"
                                                 Maximum="100" />

                                    <!-- Row 3 -->
                                    <CCToolKit:WrapPanel Orientation="Horizontal"
                                                         HorizontalSpacing="10"
                                                         VerticalSpacing="4">
                                        <TextBlock Text="{x:Bind TransferModeSummary, Mode=OneWay}"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind AddedAtText, Mode=OneWay}"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </CCToolKit:WrapPanel>

                                    <!-- Row 4 -->
                                    <CCToolKit:WrapPanel Orientation="Horizontal"
                                                         HorizontalSpacing="12"
                                                         VerticalSpacing="5">
                                        <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   TextWrapping="WrapWholeWords"
                                                   IsTextSelectionEnabled="True"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Text="{x:Bind DestinationDirectory, Mode=OneWay}"
                                                   IsTextSelectionEnabled="True"
                                                   TextWrapping="WrapWholeWords"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                    </CCToolKit:WrapPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Text="{x:Bind ViewModel.EmptyStateText, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="10"
                       IsHitTestVisible="False"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
        </Grid>

    </Grid>
</Page>