<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AppControlManager.Pages.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CC="using:CommonCore.Others"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:VM="using:AppControlManager.ViewModels"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">

    <ScrollViewer>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <customUI:InfoBarV2 Grid.Row="0"
                                Margin="0,0,0,5"
                                IsOpen="{x:Bind ViewModel.MainInfoBar.IsOpen, Mode=TwoWay}"
                                Message="{x:Bind ViewModel.MainInfoBar.Message, Mode=OneWay}"
                                Severity="{x:Bind ViewModel.MainInfoBar.Severity, Mode=OneWay}"
                                IsClosable="{x:Bind ViewModel.MainInfoBar.IsClosable, Mode=OneWay}"/>

            <StackPanel HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}"
                        Grid.Row="1">
                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                </StackPanel.ChildrenTransitions>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="BackupAndRestoreSettingsSectionHeader" />

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" x:Uid="BackupAndRestoreSettingsSectionHeader" />
                <CCToolKit:SettingsCard x:Uid="SettingsBackupRestoreSettingsCard"
                                        IsClickEnabled="True"
                                        IsActionIconVisible="True"
                                        Click="{x:Bind ViewModel.OpenSettingsBackupRestorePage}">
                    <CCToolKit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xED10;" />
                    </CCToolKit:SettingsCard.HeaderIcon>
                </CCToolKit:SettingsCard>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="UserConfigurations" />

                <CCToolKit:SettingsExpander x:Uid="UserConfigsSettingsExpander"
                                            IsEnabled="{x:Bind ViewModel.IsElevated, Mode=OneTime}"
                                            IsExpanded="{x:Bind ViewModel.MainUserConfigurationsSettingsExpanderIsExpanded, Mode=TwoWay}">
                    <CCToolKit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE71D;" />
                    </CCToolKit:SettingsExpander.HeaderIcon>

                    <Button x:Uid="RetrieveTheUserConfigurationsButton"
                            Click="{x:Bind ViewModel.GetConfigurationButton}"
                            Style="{StaticResource AccentButtonStyle}">
                        <Button.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE9F3;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <CCToolKit:SettingsExpander.Items>
                        <CCToolKit:SettingsCard ContentAlignment="Left">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                <!-- Certificate Common Name -->
                                <CCToolKit:WrapPanel Orientation="Horizontal" Margin="0,0,0,10">

                                    <AutoSuggestBox
                                        x:Uid="CertificateCommonNameAutoSuggestBox"
                                        QueryIcon="Find"
                                        GotFocus="{x:Bind ViewModel.CertificateCommonNameAutoSuggestBox_GotFocus}"
                                        IsSuggestionListOpen="{x:Bind ViewModel.CertCNAutoSuggestBoxIsSuggestionListOpen, Mode=TwoWay}"
                                        Text="{x:Bind ViewModel.CertCNsAutoSuggestBoxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="{x:Bind ViewModel.CertificateCNAutoSuggestBox_TextChanged}"
                                        ItemsSource="{x:Bind ViewModel.CertCommonNames, Mode=OneWay}"
                                        MinWidth="300" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                    <CommandBar Background="Transparent" IsOpen="False" DefaultLabelPosition="Right" VerticalAlignment="Center" Margin="0,25,0,0">
                                        <AppBarButton Icon="Save" x:Uid="SaveAppBarButton" Click="{x:Bind ViewModel.EditButton_CertificateCommonName_Click}"/>
                                        <AppBarButton Icon="Clear" x:Uid="ClearAppBarButton" Click="{x:Bind ViewModel.ClearButton_CertificateCommonName_Click}"/>
                                        <AppBarButton Icon="Refresh" x:Uid="RefreshAppBarButton" Click="{x:Bind ViewModel.FetchLatestCertificateCNs}"/>
                                    </CommandBar>
                                </CCToolKit:WrapPanel>

                                <!-- Certificate Path -->
                                <CCToolKit:WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBox x:Uid="CertificatePathTextBox" Text="{x:Bind ViewModel.CertificatePathTextBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="300" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <CommandBar Background="Transparent" IsOpen="False" DefaultLabelPosition="Right" VerticalAlignment="Center" Margin="0,25,0,0">
                                        <AppBarButton Icon="Save" x:Uid="SaveAppBarButton" Click="{x:Bind ViewModel.EditButton_CertificatePath_Click}"/>
                                        <AppBarButton Icon="Clear" x:Uid="ClearAppBarButton" Click="{x:Bind ViewModel.ClearButton_CertificatePath_Click}"/>
                                        <AppBarButton Icon="Folder" x:Uid="BrowseAppBarButton" Click="{x:Bind ViewModel.BrowseButton_CertificatePath_Click}"/>
                                    </CommandBar>
                                </CCToolKit:WrapPanel>

                            </StackPanel>
                        </CCToolKit:SettingsCard>
                    </CCToolKit:SettingsExpander.Items>
                </CCToolKit:SettingsExpander>

                <!-- Appearance section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" x:Uid="Appearance" />
                <CCToolKit:SettingsExpander x:Uid="AppearanceSectionSettingsExpander" IsExpanded="True">
                    <CCToolKit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE790;" />
                    </CCToolKit:SettingsExpander.HeaderIcon>

                    <Button x:Uid="ChangeWindowsAccentColorButton"
                            Click="{x:Bind ViewModel.OpenWindowsSettings}">
                        <Button.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xEABC;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <CCToolKit:SettingsExpander.Items>

                        <customUI:SettingsCardV2 x:Uid="DarkerBackGroundSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xF0E8;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.NavViewBackground, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="BackgroundStyleSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xEF1F;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModelMainWindow.BackDropComboBoxSelectedIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectionChanged="{x:Bind ViewModel.AppThemeSetting_SelectionChanged}">
                                <x:String>Mica Alt</x:String>
                                <x:String>Mica</x:String>
                                <x:String>Acrylic</x:String>
                                <x:String>Thin Acrylic</x:String>
                                <x:String>Custom Mica</x:String>
                                <x:String>Custom Blur</x:String>
                            </ComboBox>
                        </customUI:SettingsCardV2>

                        <!-- Acrylic Thin Options -->

                        <CCToolKit:SettingsCard x:Uid="AcrylicThinLuminosityOpacitySettingsCard"
                                               Visibility="{x:Bind ViewModel.AcrylicThinConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.01"
                                    ValueChanged="{x:Bind ViewModel.AcrylicThinLuminosityOpacitySlider_ValueChanged}"
                                    SmallChange="0.01" Value="{x:Bind ViewModel.AppSettings.AcrylicThinLuminosityOpacity, Mode=TwoWay}" />
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="AcrylicThinTintOpacitySettingsCard"
                                               Visibility="{x:Bind ViewModel.AcrylicThinConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.01"
                                    SmallChange="0.01" Value="{x:Bind ViewModel.AppSettings.AcrylicThinTintOpacity, Mode=TwoWay}" />
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="AcrylicThinTintColorSettingsCard"
                                               Visibility="{x:Bind ViewModel.AcrylicThinConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <ColorPicker Loaded="{x:Bind ViewModel.AcrylicThinTintColorPicker_Loaded}"
                                         ColorSpectrumShape="Ring"
                                         IsMoreButtonVisible="True"
                                         IsColorSliderVisible="True"
                                         IsColorChannelTextInputVisible="True"
                                         IsHexInputVisible="True"
                                         IsAlphaEnabled="False"
                                         ColorChanged="{x:Bind ViewModel.TintColorPicker_ColorChanged}"
                                         IsAlphaSliderVisible="False"
                                         IsAlphaTextInputVisible="False" />
                        </CCToolKit:SettingsCard>

                        <!-- End of Acrylic Thin Options -->

                        <!-- BackdropMicaBrush Options -->

                        <CCToolKit:SettingsCard x:Uid="BackdropMicaBrushLuminosityOpacitySettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropMicaBrushConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.01"
                                    ValueChanged="{x:Bind ViewModel.BackdropMicaBrushLuminosityOpacitySlider_ValueChanged}"
                                    SmallChange="0.01" Value="{x:Bind ViewModel.AppSettings.BackdropMicaBrushLuminosityOpacity, Mode=TwoWay}" />
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="BackdropMicaBrushTintOpacitySettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropMicaBrushConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.01"
                                    SmallChange="0.01" Value="{x:Bind ViewModel.AppSettings.BackdropMicaBrushTintOpacity, Mode=TwoWay}"
                                    ValueChanged="{x:Bind ViewModel.BackdropMicaBrushTintOpacity_ValueChanged}"/>
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="BackdropMicaBrushBlurAmountSettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropMicaBrushConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <Slider Width="200" Minimum="1" Maximum="100" StepFrequency="1"
                                    SmallChange="1" Value="{x:Bind ViewModel.AppSettings.BackdropMicaBrushBlurAmount, Mode=TwoWay}"
                                    ValueChanged="{x:Bind ViewModel.BackdropMicaBrushBlurAmount_ValueChanged}"/>
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="BackdropMicaBrushTintColorSettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropMicaBrushConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <ColorPicker Loaded="{x:Bind ViewModel.BackdropMicaBrushTintColorPicker_Loaded}"
                                         ColorSpectrumShape="Ring"
                                         IsMoreButtonVisible="True"
                                         IsColorSliderVisible="True"
                                         IsColorChannelTextInputVisible="True"
                                         IsHexInputVisible="True"
                                         IsAlphaEnabled="False"
                                         ColorChanged="{x:Bind ViewModel.BackdropMicaBrushTintColorPicker_ColorChanged}"
                                         IsAlphaSliderVisible="False"
                                         IsAlphaTextInputVisible="False" />
                        </CCToolKit:SettingsCard>

                        <!-- End of BackdropMicaBrush Options -->

                        <!-- BackdropBlurBrush Options -->

                        <CCToolKit:SettingsCard x:Uid="BackdropBlurBrushTintOpacitySettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropBlurBrushConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <Slider Width="200" Minimum="0" Maximum="1" StepFrequency="0.01"
                                    SmallChange="0.01" Value="{x:Bind ViewModel.AppSettings.BackdropBlurBrushTintOpacity, Mode=TwoWay}"
                                    ValueChanged="{x:Bind ViewModel.BackdropBlurBrushTintOpacity_ValueChanged}"/>
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="BackdropBlurBrushBlurAmountSettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropBlurBrushConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <Slider Width="200" Minimum="1" Maximum="100" StepFrequency="1"
                                    SmallChange="1" Value="{x:Bind ViewModel.AppSettings.BackdropBlurBrushBlurAmount, Mode=TwoWay}"
                                    ValueChanged="{x:Bind ViewModel.BackdropBlurBrushBlurAmount_ValueChanged}"/>
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="BackdropBlurBrushTintColorSettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropBlurBrushConfigurationsSettingsCardVisibility, Mode=OneWay}">
                            <ColorPicker Loaded="{x:Bind ViewModel.BackdropBlurBrushTintColorPicker_Loaded}"
                                         ColorSpectrumShape="Ring"
                                         IsMoreButtonVisible="True"
                                         IsColorSliderVisible="True"
                                         IsColorChannelTextInputVisible="True"
                                         IsHexInputVisible="True"
                                         IsAlphaEnabled="False"
                                         ColorChanged="{x:Bind ViewModel.BackdropBlurBrushTintColorPicker_ColorChanged}"
                                         IsAlphaSliderVisible="False"
                                         IsAlphaTextInputVisible="False" />
                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="BackdropBlurBrushBackgroundPictureSettingsCard"
                                               Visibility="{x:Bind ViewModel.BackdropCustomBrushPictureSelectionSettingsCardVisibility, Mode=OneWay}">

                            <customUI:SplitButtonV2 x:Uid="FileBrowseButton"
                                                    ObservedData="{x:Bind ViewModel.AppSettings.BackdropCustomBrushPictureSelection, Mode=OneWay}"
                                                    Click="{x:Bind ViewModel.BackdropBlurBrushBrowseForPicButton_Click}">

                                <customUI:SplitButtonV2.ContentTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8DA;" FontSize="16"/>
                                            <TextBlock Text="{x:Bind}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </customUI:SplitButtonV2.ContentTemplate>

                                <customUI:SplitButtonV2.Flyout>
                                    <Flyout>

                                        <CCToolKit:WrapPanel Orientation="Vertical" HorizontalSpacing="10" VerticalSpacing="5">

                                            <Button x:Uid="ResetButton" Click="{x:Bind ViewModel.ClearBackdropCustomBrushPictureSelection}" />

                                            <TextBlock x:Uid="ViewSelectedFilesTextBlock" TextWrapping="WrapWholeWords" />

                                            <TextBox Text="{x:Bind ViewModel.AppSettings.BackdropCustomBrushPictureSelection, Mode=OneWay}"
                                                     TextWrapping="Wrap" AcceptsReturn="True" IsSpellCheckEnabled="False"
                                                     MinWidth="400" IsReadOnly="True" />

                                        </CCToolKit:WrapPanel>

                                    </Flyout>
                                </customUI:SplitButtonV2.Flyout>

                            </customUI:SplitButtonV2>

                        </CCToolKit:SettingsCard>

                        <!-- End of BackdropBlurBrush Options -->

                        <customUI:SettingsCardV2 x:Uid="AppThemeSettingsCard"
                                                 Visibility="{x:Bind ViewModel.AppThemeSettingsCardVisibility, Mode=OneWay}" >
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE706;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.AppThemeComboBoxSelectedIndex, Mode=TwoWay}">
                                <x:String>Use System Setting</x:String>
                                <x:String>Dark</x:String>
                                <x:String>Light</x:String>
                            </ComboBox>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="MainNavigationIconsSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE8D3;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.IconsStylesComboBoxSelectedIndex, Mode=TwoWay}">
                                <x:String>Animated</x:String>
                                <x:String>Windows Accent</x:String>
                                <x:String>Monochromatic</x:String>
                            </ComboBox>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="MainNavigationLocationSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE90C;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.NavigationMenuLocationComboBoxSelectedIndex, Mode=TwoWay}">
                                <x:String>Left</x:String>
                                <x:String>Top</x:String>
                            </ComboBox>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="AppWindowBorderColorSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xEF3C;" />
                            </customUI:SettingsCardV2.HeaderIcon>

                            <StackPanel HorizontalAlignment="Center">
                                <ComboBox x:Name="BorderTypeSelection"
                                          Margin="0,0,0,8"
                                          HorizontalAlignment="Center"
                                          SelectedIndex="0">
                                    <x:String>Rainbow</x:String>
                                    <x:String>Custom Color</x:String>
                                </ComboBox>

                                <!-- SwitchPresenter binds to a TargetValue -->
                                <CCToolKit:SwitchPresenter TargetValue="{x:Bind BorderTypeSelection.SelectedItem, Mode=OneWay}">
                                    <!--And then only dynamically displays the Case with the matching TargetValue -->

                                    <CCToolKit:Case TargetValue="Rainbow">
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="10">
                                            <Button x:Uid="RainbowBorderAnimationStartButton" HorizontalAlignment="Center" Click="{x:Bind ViewModel.StartRainbowAnimation}">
                                                <Button.ContentTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE768;" FontSize="16"/>
                                                            <TextBlock Text="{x:Bind}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Button.ContentTemplate>
                                            </Button>
                                            <Button x:Uid="RainbowBorderAnimationStopButton" HorizontalAlignment="Center" Click="{x:Bind ViewModel.StopRainbowAnimation}">
                                                <Button.ContentTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE71A;" FontSize="16"/>
                                                            <TextBlock Text="{x:Bind}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Button.ContentTemplate>
                                            </Button>
                                        </StackPanel>
                                    </CCToolKit:Case>

                                    <CCToolKit:Case TargetValue="Custom Color">

                                        <CCToolKit:WrapPanel Orientation="Vertical"
                                                            HorizontalSpacing="10"
                                                            VerticalSpacing="10">

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Spacing="10">
                                                <Button x:Uid="SetBorderColorButton"
                                                        HorizontalAlignment="Center"
                                                        Click="{x:Bind ViewModel.StartCustomColorAnimation}">
                                                    <Button.ContentTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE8FB;" FontSize="16"/>
                                                                <TextBlock Text="{x:Bind}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                                <Button x:Uid="ResetBorderColorButton"
                                                        HorizontalAlignment="Center"
                                                        Click="{x:Bind ViewModel.StopCustomColorAnimation}">
                                                    <Button.ContentTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE7A7;" FontSize="16"/>
                                                                <TextBlock Text="{x:Bind}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>

                                            </StackPanel>

                                            <ColorPicker ColorSpectrumShape="Ring"
                                                         IsMoreButtonVisible="False"
                                                         IsColorSliderVisible="False"
                                                         IsColorChannelTextInputVisible="False"
                                                         IsHexInputVisible="False"
                                                         IsAlphaEnabled="False"
                                                         ColorChanged="{x:Bind ViewModel.ColorPicker_ColorChanged}"
                                                         IsAlphaSliderVisible="False"
                                                         IsAlphaTextInputVisible="False" />

                                        </CCToolKit:WrapPanel>

                                    </CCToolKit:Case>
                                </CCToolKit:SwitchPresenter>

                            </StackPanel>

                        </customUI:SettingsCardV2>

                    </CCToolKit:SettingsExpander.Items>

                </CCToolKit:SettingsExpander>

                <!-- Behavior section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" x:Uid="Behavior" />
                <CCToolKit:SettingsExpander IsExpanded="True" x:Uid="BehaviorSettingSettingsExpander">
                    <CCToolKit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE9E9;" />
                    </CCToolKit:SettingsExpander.HeaderIcon>
                    <CCToolKit:SettingsExpander.Items>
                        <customUI:SettingsCardV2 x:Uid="ListViewsCenterVerticallyUponSelectionSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE8E3;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.ListViewsVerticalCentering, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>
                        <customUI:SettingsCardV2 x:Uid="CacheSecurityCatalogsScanResultsSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE96A;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.CacheSecurityCatalogsScanResults, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>
                        <customUI:SettingsCardV2 x:Uid="PromptForElevationSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE7EF;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.PromptForElevationOnStartup, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>
                        <customUI:SettingsCardV2 x:Uid="ScreenShieldSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xEE3F;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.ScreenShield, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>
                        <customUI:SettingsCardV2 x:Uid="PublishUserActivityInTheOSSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xEC5B;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.PublishUserActivityInTheOS, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="BrowseForCISchemaSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xF193;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <CCToolKit:WrapPanel HorizontalSpacing="10" Orientation="Vertical" VerticalSpacing="10">

                                <Button Click="{x:Bind ViewModel.BrowseForCISchemaPath}"
                                        HorizontalAlignment="Center"
                                        x:Uid="BrowseForCISchemaButton">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xEC50;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>

                                <TextBox IsReadOnly="True"
                                         Text="{x:Bind ViewModel.AppSettings.CiPolicySchemaPath, Mode=OneWay}"
                                         HorizontalAlignment="Center"
                                         x:Uid="CustomCISchemaPathTextBox"/>

                            </CCToolKit:WrapPanel>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="AutoResizeListViewColumnsSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE73F;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.AutoResizeListViewColumns, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>

                        <!-- https://microsoft.github.io/Win2D/WinUI2/html/M_Microsoft_Graphics_Canvas_Text_CanvasTextFormat_GetSystemFontFamilies.htm -->
                        <customUI:SettingsCardV2 x:Uid="ListViewFontFamilySettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE8D2;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ComboBox ItemsSource="{x:Bind ViewModel.FontFamilies}"
                                      SelectedItem="{x:Bind ViewModel.AppSettings.ListViewFontFamily, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock Text="{x:Bind}" VerticalAlignment="Center" FontFamily="{x:Bind VM:ViewModelProvider.SettingsVM.AppSettings.ListViewFontFamily, Mode=OneWay}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="UseV2CIManagementSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE794;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.UseV2CIManagement, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="AppCloseConfirmationSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE7E8;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.AppSettings.AppCloseConfirmationBehavior, Mode=TwoWay}">
                                <ComboBoxItem x:Uid="AppCloseConfirmationOptionAlwaysSettingsCard" />
                                <ComboBoxItem x:Uid="AppCloseConfirmationOptionAutomaticSettingsCard" />
                                <ComboBoxItem x:Uid="AppCloseConfirmationOptionNeverSettingsCard" />
                            </ComboBox>
                        </customUI:SettingsCardV2>

                    </CCToolKit:SettingsExpander.Items>
                </CCToolKit:SettingsExpander>

                <!-- Notifications section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" x:Uid="Notifications" />
                <CCToolKit:SettingsExpander IsExpanded="True" x:Uid="NotificationSettingsSettingsExpander">
                    <CCToolKit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE7E7;" />
                    </CCToolKit:SettingsExpander.HeaderIcon>

                    <CCToolKit:SettingsExpander.Items>
                        <customUI:SettingsCardV2 x:Uid="EnableToastNotificationsSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xF6C5;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.ToastNotificationsAreEnabled, Mode=TwoWay}"
                                          x:Uid="ToggleSwitchGeneral"/>
                        </customUI:SettingsCardV2>

                        <customUI:SettingsCardV2 x:Uid="RemoveAllToastNotificationsSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE894;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <Button Click="{x:Bind ViewModel.RemoveAllToastNotifications}" x:Uid="RemoveAllToastNotificationsButton" />
                        </customUI:SettingsCardV2>

                    </CCToolKit:SettingsExpander.Items>

                </CCToolKit:SettingsExpander>

                <!-- Language section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" x:Uid="LanguageTextBlock" />
                <CCToolKit:SettingsExpander IsExpanded="True" x:Uid="LanguageSettingSettingsExpander">
                    <CCToolKit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xF2B7;" />
                    </CCToolKit:SettingsExpander.HeaderIcon>

                    <CCToolKit:SettingsExpander.Items>
                        <customUI:SettingsCardV2 x:Uid="LanguageSelectionSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xF69E;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ComboBox ItemsSource="{x:Bind ViewModel.LanguageOptions}"
                                      SelectedIndex="{x:Bind ViewModel.LanguageComboBoxSelectedIndex, Mode=TwoWay}">

                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="CC:LanguageOption">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Ellipse Width="24" Height="24">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{x:Bind Image}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>

                            </ComboBox>
                        </customUI:SettingsCardV2>
                        <customUI:SettingsCardV2 x:Uid="UIFlowDirectionSettingsCard">
                            <customUI:SettingsCardV2.HeaderIcon>
                                <FontIcon Glyph="&#xE9AB;" />
                            </customUI:SettingsCardV2.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.UIFlowDirectionToggleSwitch, Mode=TwoWay}"
                                          Toggled="{x:Bind ViewModel.FlowDirectionToggleSwitch_Toggled}"
                                          x:Uid="UIFlowDirectionToggleSwitch" />
                        </customUI:SettingsCardV2>
                    </CCToolKit:SettingsExpander.Items>
                </CCToolKit:SettingsExpander>

                <!-- Sound section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" x:Uid="Sound" />
                <customUI:SettingsCardV2 x:Uid="AppSoundSettingSettingsCard">
                    <customUI:SettingsCardV2.HeaderIcon>
                        <FontIcon Glyph="&#xEC4F;" />
                    </customUI:SettingsCardV2.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.SoundSetting, Mode=TwoWay}"
                                  x:Uid="ToggleSwitchGeneral"/>
                </customUI:SettingsCardV2>

                <!-- About section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="About" />
                <CCToolKit:SettingsExpander Header="AppControl Manager"
                                           IsExpanded="True"
                                           Description="{x:Bind ViewModel.CopyRightSettingsExpanderDescription, Mode=OneTime}">
                    <CCToolKit:SettingsExpander.HeaderIcon>
                        <BitmapIcon UriSource="ms-appx:///Assets/Square44x44Logo.altform-lightunplated_targetsize-256.png"
                                    ShowAsMonochrome="False" />
                    </CCToolKit:SettingsExpander.HeaderIcon>
                    <TextBlock Text="{x:Bind ViewModel.VersionTextBlockText, Mode=OneTime}" IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <CCToolKit:SettingsExpander.Items>
                        <CCToolKit:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">

                            <CCToolKit:WrapPanel Margin="-12,0,0,0" Orientation="Horizontal" HorizontalSpacing="13">

                                <StackPanel Orientation="Vertical">
                                    <HyperlinkButton x:Uid="GitHubRepoHyperLinkButton" NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security" />
                                    <HyperlinkButton x:Uid="AppControlManagerDocumentationHyperLinkButton" NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security/wiki/AppControl-Manager" />
                                    <HyperlinkButton x:Uid="MicrosoftStorePageHyperLinkButton" NavigateUri="https://apps.microsoft.com/detail/9PNG1JDDTGP8" />
                                </StackPanel>

                                <StackPanel Orientation="Vertical">
                                    <HyperlinkButton x:Uid="SpyNetGirlWebsiteHyperLinkButton" NavigateUri="https://spynetgirl.github.io/" />
                                    <HyperlinkButton x:Uid="YouTubeChannelHyperLinkButton" NavigateUri="https://www.youtube.com/@hotcakex" />
                                    <HyperlinkButton x:Uid="DonationHyperLinkButton" FontWeight="ExtraBold" NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security?tab=readme-ov-file#donations-" />
                                </StackPanel>

                                <StackPanel Orientation="Vertical">
                                    <HyperlinkButton Content="X" NavigateUri="https://x.com/CyberCakeX" />
                                    <HyperlinkButton x:Uid="PrivacyPolicyHyperLinkButton" NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security/wiki/Privacy-Policy-for-the-AppControl-Manager" />
                                </StackPanel>

                            </CCToolKit:WrapPanel>

                        </CCToolKit:SettingsCard>
                    </CCToolKit:SettingsExpander.Items>
                </CCToolKit:SettingsExpander>

                <CCToolKit:WrapPanel Orientation="Horizontal" HorizontalSpacing="10" VerticalSpacing="10" Margin="0,8,0,0">
                    <HyperlinkButton x:Uid="SendFeedbackHyperLinkButton" NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security/issues/new/choose">
                        <HyperlinkButton.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xED15;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </HyperlinkButton.ContentTemplate>
                    </HyperlinkButton>

                    <HyperlinkButton x:Uid="Icons8WebsiteHyperLinkButton" NavigateUri="https://icons8.com">
                        <HyperlinkButton.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xED58;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </HyperlinkButton.ContentTemplate>
                    </HyperlinkButton>

                    <HyperlinkButton x:Uid="SourceCodeHyperLinkButton" NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security/tree/main/AppControl%20Manager">
                        <HyperlinkButton.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE943;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </HyperlinkButton.ContentTemplate>
                    </HyperlinkButton>

                    <TextBlock x:Uid="Sponsor1TextBlock" FontStyle="Italic" Margin="0,6,0,0" />
                </CCToolKit:WrapPanel>

            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>
