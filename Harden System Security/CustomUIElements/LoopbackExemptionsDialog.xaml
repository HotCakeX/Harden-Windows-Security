<customUI:ContentDialogV2
    x:Class="HardenSystemSecurity.CustomUIElements.LoopbackExemptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CC="using:CommonCore.Others"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    DefaultButton="Close">

    <Grid MinWidth="760"
          MinHeight="520"
          Padding="4"
          RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <TextBlock Text="{x:Bind SummaryText, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords" />
        </Border>

        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind IsInfoBarOpen, Mode=OneWay}"
                 Message="{x:Bind InfoBarMessage, Mode=OneWay}"
                 Severity="{x:Bind InfoBarSeverity, Mode=OneWay}"
                 IsClosable="False" />

        <CCToolKit:WrapPanel Grid.Row="2"
                             xmlns:CCToolKit="using:CommonCore.ToolKits"
                             Orientation="Horizontal"
                             HorizontalSpacing="8"
                             VerticalSpacing="8">
            <ProgressRing Visibility="{x:Bind BusyVisibility, Mode=OneWay}"
                          IsIndeterminate="True"
                          VerticalAlignment="Center" />

            <Button x:Uid="LoopbackDialogRefreshButton"
                    IsEnabled="{x:Bind ActionsAreEnabled, Mode=OneWay}"
                    Click="RefreshButton_Click" />

            <Button x:Uid="LoopbackDialogAddAllButton"
                    IsEnabled="{x:Bind ActionsAreEnabled, Mode=OneWay}"
                    Click="AddAllButton_Click" />

            <Button x:Uid="LoopbackDialogClearAllButton"
                    IsEnabled="{x:Bind ActionsAreEnabled, Mode=OneWay}"
                    Click="ClearAllButton_Click" />
        </CCToolKit:WrapPanel>

        <Border Grid.Row="3"
                Padding="8"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <ListView ItemsSource="{x:Bind Entries, Mode=OneWay}"
                      SelectionMode="None"
                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                      ShowsScrollingPlaceholders="True">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="CC:AppContainerLoopbackEntry">
                        <Border Margin="0,4"
                                Padding="10"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Spacing="6">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Text="{x:Bind DisplayName}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="WrapWholeWords" />
                                        <Border Padding="8,2"
                                                CornerRadius="10"
                                                Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                            <TextBlock Text="{x:Bind EntryTypeText}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{x:Bind PackageFamilyNameOrPlaceholder}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords" />

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <TextBlock x:Uid="LoopbackDialogSidLabel"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind Sid}"
                                                   IsTextSelectionEnabled="True"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Spacing="8"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind StatusText}"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Right"
                                               TextAlignment="Right" />

                                    <Button Content="{x:Bind ActionButtonText}"
                                            IsEnabled="{x:Bind CanModify}"
                                            Click="EntryActionButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</customUI:ContentDialogV2>
