<UserControl
    x:Class="AppControlManager.CustomUIElements.GraphAuthPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:AnimatedVisuals"
    xmlns:MSGraph="using:CommonCore.MicrosoftGraph"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    Loaded="{x:Bind GraphAuthPanel_Loaded}">
    <UserControl.Resources>
        <DataTemplate x:Key="AuthenticatedAccountCardTemplate" x:DataType="MSGraph:AuthenticatedAccounts">
            <Border Width="500"
                    HorizontalAlignment="Center"
                    CornerRadius="10"
                    Padding="6"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Loaded="{x:Bind LoadProfilePhotoSilently}">
                <Grid RowSpacing="6">
                    <Grid.Resources>
                        <ResourceDictionary Source="ms-appx:///Microsoft.UI.Xaml/DensityStyles/Compact.xaml"/>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Width="46"
                                Height="46"
                                Padding="0"
                                x:Uid="ProfilePhotoButton"
                                Click="{x:Bind LoadProfilePhotoWithConsent}">
                            <PersonPicture Width="42"
                                           Height="42"
                                           DisplayName="{x:Bind Username, Mode=OneWay}"
                                           Initials="{x:Bind Initials, Mode=OneWay}"
                                           ProfilePicture="{x:Bind ProfilePhotoImageSource, Mode=OneWay}"/>
                        </Button>
                        <StackPanel Grid.Column="1"
                                    Spacing="1"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Username, Mode=OneWay}"
                                           IsTextSelectionEnabled="True"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Padding="8,2"
                                        CornerRadius="10"
                                        Visibility="{x:Bind ActiveAccountBadgeVisibility, Mode=OneWay}"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock x:Uid="ActiveAccountBadgeTextBlock"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" ColumnSpacing="6" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Grid.Column="0"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="AccountTenantIDHeaderTextBlock"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyTenantID}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind TenantID, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="AccountIdentifierHeaderTextBlock"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyAccountIdentifier}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind AccountIdentifier, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="ContextHeader"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyAuthContext}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind AuthContext, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="AccountEnvironmentHeaderTextBlock"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyEnvironment}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind Environment, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Height="76"
                                CornerRadius="8"
                                Padding="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           x:Uid="AccountPermissionsHeaderTextBlock"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyPermissions}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                                </Button>
                                <ScrollViewer Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              VerticalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled">
                                    <TextBlock Text="{x:Bind Permissions, Mode=OneWay}"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AuthenticatedAccountCardWithActionsTemplate" x:DataType="MSGraph:AuthenticatedAccounts">
