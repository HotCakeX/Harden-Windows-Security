<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AppControlManager.Pages.Logs"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:systemIO="using:System.IO"
    xmlns:VMs="using:AppControlManager.ViewModels"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CCToolKit:WrapPanel Orientation="Horizontal" Grid.Row="0" Margin="10" HorizontalSpacing="10" VerticalSpacing="10" XYFocusKeyboardNavigation="Enabled">
            <!-- ComboBox for selecting log files -->
            <ComboBox ItemsSource="{x:Bind ViewModel.LogFiles}"
                      HorizontalContentAlignment="Stretch"
                      SelectedItem="{x:Bind ViewModel.SelectedLogFile, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="systemIO:FileInfo">
                        <Grid ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind Name}"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1"                                    
                                    Style="{StaticResource SubtleButtonStyle}"                                                                   
                                    IsEnabled="{x:Bind VMs:ViewModelProvider.LogsVM.CanDeleteLogFile(FullName), Mode=OneWay}"
                                    Click="{x:Bind VMs:ViewModelProvider.LogsVM.DeleteLogFile_Click}"
                                    Tag="{x:Bind}">
                                <SymbolIcon Symbol="Delete" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Button to refresh the logs -->
            <Button x:Uid="RefreshLogFilesButton"
                    Click="{x:Bind ViewModel.LoadLogFiles}"
                    Style="{StaticResource AccentButtonStyle}"
                    AccessKey="R">
                <Button.ContentTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE895;" FontSize="16"/>
                            <TextBlock Text="{x:Bind}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Click="{x:Bind ViewModel.OpenLogsDirectory}"
                    AccessKey="O">
                <StackPanel Orientation="Horizontal" Spacing="4">

                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                              Glyph="&#xE838;"
                              VerticalAlignment="Center"/>

                    <TextBlock x:Uid="OpenLogsDirectoryButtonText"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Uid="CopySelectedButton" Click="{x:Bind ViewModel.CopySelectedLogLines}"
                    AccessKey="C">
                <Button.ContentTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C8;" FontSize="16"/>
                            <TextBlock Text="{x:Bind}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <!-- Search TextBox -->
            <TextBox x:Uid="SearchBoxTextBox"
                     VerticalAlignment="Center"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Progress Ring for loading indication -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"
                          Width="24"
                          Height="24"
                          VerticalAlignment="Center" />

        </CCToolKit:WrapPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.LogCollection, Mode=OneWay}"
                  SelectionMode="Multiple"
                  IsItemClickEnabled="False"
                  Loaded="{x:Bind ViewModel.ListView_Loaded}"
                  ScrollViewer.HorizontalScrollMode="Disabled"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollMode="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.ZoomMode="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock Text="{x:Bind}"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"
                               FontSize="18"
                               Margin="5"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
