                                            <Setter Target="PART_ContentPresenter.(Grid.Column)" Value="1" />
                                            <Setter Target="PART_ContentPresenter.HorizontalAlignment" Value="Stretch" />
                                            <Setter Target="PART_ContentPresenter.HorizontalContentAlignment" Value="Left" />
