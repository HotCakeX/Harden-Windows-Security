<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AppControlManager.Pages.BuildNewCertificate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">

    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Margin="10,5,10,5"
                    IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}"
                    Click="{x:Bind ViewModel.BuildCertificateButton_Click}"
                    x:Uid="BuildCertificateButton">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <ProgressRing Visibility="{x:Bind ViewModel.ProgressRingVisibility, Mode=OneWay}"
                                      Margin="5,5,15,5"
                                      Value="0"
                                      IsIndeterminate="True"
                                      Minimum="0"
                                      Maximum="100"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xEB77;" Margin="5" />
                            <TextBlock x:Uid="BuildCertificateTextBlock" Margin="5"/>
                        </StackPanel>

                    </StackPanel>
                </Button.Content>
            </Button>

            <customUI:InfoBarV2
                IsOpen="{x:Bind ViewModel.MainInfoBar.IsOpen, Mode=TwoWay}"
                Severity="{x:Bind ViewModel.MainInfoBar.Severity, Mode=OneWay}"
                IsClosable="{x:Bind ViewModel.MainInfoBar.IsClosable, Mode=OneWay}"
                Message="{x:Bind ViewModel.MainInfoBar.Message, Mode=OneWay}"
                Title="{x:Bind ViewModel.MainInfoBar.Title, Mode=OneWay}"
                Grid.Row="1">
                <customUI:InfoBarV2.ActionButton>
                    <Button Visibility="{x:Bind ViewModel.CopyInfoBarToClipboardButtonVisibility, Mode=OneWay}"
                            x:Uid="CopyThumbPrintToClipboardButton"
                            Click="{x:Bind ViewModel.CopyInfoBarToClipboardButton_Click}">
                        <Button.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </customUI:InfoBarV2.ActionButton>
            </customUI:InfoBarV2>

            <StackPanel HorizontalAlignment="Stretch" Spacing="{StaticResource SettingsCardSpacing}"
                        Grid.Row="2" Margin="0,5,0,0" XYFocusKeyboardNavigation="Enabled">

                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                </StackPanel.ChildrenTransitions>

                <customUI:SettingsCardV2 x:Uid="KeySizeSettingsCard"
                                         IsClickEnabled="True"
                                         IsActionIconVisible="False">
                    <customUI:SettingsCardV2.HeaderIcon>
                        <FontIcon Glyph="&#xF4A5;" />
                    </customUI:SettingsCardV2.HeaderIcon>

                    <ComboBox SelectedItem="{x:Bind ViewModel.KeySizeComboBoxSelectedItem, Mode=TwoWay}"
                              IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}">
                        <x:String>4096</x:String>
                    </ComboBox>

                </customUI:SettingsCardV2>

                <customUI:SettingsCardV2 x:Uid="AlgorithmSettingsCard"
                          IsClickEnabled="True"
                          IsActionIconVisible="False">
                    <customUI:SettingsCardV2.HeaderIcon>
                        <FontIcon Glyph="&#xF4A5;" />
                    </customUI:SettingsCardV2.HeaderIcon>

                    <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedHashAlgorithm, Mode=TwoWay}"
                              IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}">
                        <x:String>SHA2_256</x:String>
                        <x:String>SHA2_384</x:String>
                        <x:String>SHA2_512</x:String>
                        <x:String>SHA3_256</x:String>
                        <x:String>SHA3_384</x:String>
                        <x:String>SHA3_512</x:String>
                    </ComboBox>

                </customUI:SettingsCardV2>

                <CCToolKit:SettingsCard x:Uid="CommonNameSettingsCard"
                                       IsClickEnabled="False"
                                       IsActionIconVisible="False">
                    <CCToolKit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8AC;" />
                    </CCToolKit:SettingsCard.HeaderIcon>

                    <TextBox x:Uid="CommonNameTextBox"
                             Text="{x:Bind ViewModel.CommonName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}"
                             MinWidth="200"/>

                </CCToolKit:SettingsCard>

                <CCToolKit:SettingsCard x:Uid="ValiditySettingsCard"
                                       IsClickEnabled="False"
                                       IsActionIconVisible="False">
                    <CCToolKit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE787;" />
                    </CCToolKit:SettingsCard.HeaderIcon>

                    <NumberBox Value="{x:Bind ViewModel.Validity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               SpinButtonPlacementMode="Inline"
                               SmallChange="10"
                               IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}"
                               LargeChange="100"
                               Minimum="1"
                               MaxHeight="3000"/>

                </CCToolKit:SettingsCard>

                <CCToolKit:SettingsCard x:Uid="PFXPasswordSettingsCard"
                                       IsClickEnabled="False"
                                       IsActionIconVisible="False">
                    <CCToolKit:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF78D;" />
                    </CCToolKit:SettingsCard.HeaderIcon>

                    <PasswordBox MinWidth="250"
                                 PasswordChar="#"
                                 IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}"
                                 PasswordRevealMode="Peek"
                                 Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 x:Uid="PFXEncryptionPasswordBox" />

                </CCToolKit:SettingsCard>

                <!-- Signing -->
                <CCToolKit:SettingsExpander Margin="0,20,0,0" x:Uid="SigningSettingsExpander">
                    <CCToolKit:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8A6;" />
                    </CCToolKit:SettingsExpander.HeaderIcon>

                    <SplitButton VerticalAlignment="Center"
                                 Content="Sign"
                                 IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}"
                                 Click="{x:Bind ViewModel.SignFilesButton_Click}">
                        <SplitButton.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xEF3F;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </SplitButton.ContentTemplate>
                        <SplitButton.Flyout>
                            <MenuFlyout>
                                <ToggleMenuFlyoutItem Text="Page Hashing" IsChecked="{x:Bind ViewModel.EnablePageHashing, Mode=TwoWay}"/>
                            </MenuFlyout>
                        </SplitButton.Flyout>

                    </SplitButton>

                    <CCToolKit:SettingsExpander.Items>

                        <CCToolKit:SettingsCard x:Uid="SelectFilesAndFoldersToSignSettingsCard">

                            <CCToolKit:WrapPanel Orientation="Vertical" HorizontalSpacing="10" VerticalSpacing="15">

                                <customUI:ButtonV2 IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                                                   x:Uid="FileBrowseButton"
                                                   ObservedData="{x:Bind ViewModel.SelectedFilesToSign.Count, Mode=OneWay}"
                                                   Click="{x:Bind ViewModel.BrowseForScriptFilesButton_Click}">

                                    <customUI:ButtonV2.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8DA;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </customUI:ButtonV2.ContentTemplate>

                                    <customUI:ButtonV2.Flyout>
                                        <Flyout>

                                            <CCToolKit:WrapPanel Orientation="Vertical" HorizontalSpacing="15" VerticalSpacing="15">

                                                <Button x:Uid="ClearButton" Click="{x:Bind ViewModel.Clear_SelectedFilesToSign}">
                                                    <Button.ContentTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE894;" FontSize="16"/>
                                                                <TextBlock Text="{x:Bind}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>

                                                <TextBlock x:Uid="ViewSelectedFilesTextBlock" TextWrapping="WrapWholeWords" />

                                                <customUI:ListBoxV2 MinWidth="400" SelectionMode="Single" ItemsSource="{x:Bind ViewModel.SelectedFilesToSign, Mode=OneWay}" />

                                            </CCToolKit:WrapPanel>

                                        </Flyout>
                                    </customUI:ButtonV2.Flyout>

                                </customUI:ButtonV2>

                                <customUI:ButtonV2 IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                                                   x:Uid="FolderBrowseButton"
                                                   ObservedData="{x:Bind ViewModel.SelectedFoldersToSign.Count, Mode=OneWay}"
                                                   Click="{x:Bind ViewModel.BrowseForScriptFoldersButton_Click}">

                                    <customUI:ButtonV2.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xF89A;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </customUI:ButtonV2.ContentTemplate>

                                    <customUI:ButtonV2.Flyout>
                                        <Flyout>

                                            <CCToolKit:WrapPanel Orientation="Vertical" HorizontalSpacing="15" VerticalSpacing="15">

                                                <Button x:Uid="ClearButton" Click="{x:Bind ViewModel.Clear_SelectedFoldersToSign}">
                                                    <Button.ContentTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE894;" FontSize="16"/>
                                                                <TextBlock Text="{x:Bind}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>

                                                <TextBlock x:Uid="ViewSelectedFoldersTextBlock" TextWrapping="WrapWholeWords" />

                                                <customUI:ListBoxV2 MinWidth="400" SelectionMode="Single" ItemsSource="{x:Bind ViewModel.SelectedFoldersToSign, Mode=OneWay}" />

                                            </CCToolKit:WrapPanel>

                                        </Flyout>
                                    </customUI:ButtonV2.Flyout>

                                </customUI:ButtonV2>

                            </CCToolKit:WrapPanel>

                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="CommonNameSelectionForSigningSettingsCard">

                            <TextBox Loaded="{x:Bind ViewModel.CommonNameTextBox_Loaded}"
                                     Text="{x:Bind ViewModel.SigningCertificateCNToUseForSigning, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}"/>

                        </CCToolKit:SettingsCard>

                        <CCToolKit:SettingsCard x:Uid="TimeStampURLSelectionForSigningSettingsCard">

                            <TextBox Text="{x:Bind ViewModel.SigningTimestampUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{x:Bind ViewModel.ElementsAreEnabled,Mode=OneWay}"/>

                        </CCToolKit:SettingsCard>

                    </CCToolKit:SettingsExpander.Items>

                </CCToolKit:SettingsExpander>

            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>
