<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AppControlManager.Pages.SettingsBackupRestore"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:settingsData="using:CommonCore.AppSettings"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">

    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <customUI:InfoBarV2 Grid.Row="0"                               
                                IsOpen="{x:Bind ViewModel.MainInfoBar.IsOpen, Mode=TwoWay}"
                                Message="{x:Bind ViewModel.MainInfoBar.Message, Mode=OneWay}"
                                Severity="{x:Bind ViewModel.MainInfoBar.Severity, Mode=OneWay}"
                                IsClosable="{x:Bind ViewModel.MainInfoBar.IsClosable, Mode=OneWay}"/>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                    <RepositionThemeTransition IsStaggeringEnabled="False" />
                </StackPanel.ChildrenTransitions>

                <Border Padding="8"
                        CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                    <CCToolKit:WrapPanel HorizontalSpacing="10"
                                         HorizontalAlignment="Center"
                                         VerticalSpacing="10"
                                         XYFocusKeyboardNavigation="Enabled">
                        <Button x:Uid="ExportSettingsToJsonButton"
                                Click="{x:Bind ViewModel.ExportAsync}">
                            <Button.ContentTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xEA53;" FontSize="16"/>
                                        <TextBlock Text="{x:Bind}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Uid="ImportSettingsFromJsonButton"
                                Click="{x:Bind ViewModel.ImportAsync}">
                            <Button.ContentTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8B6;" FontSize="16"/>
                                        <TextBlock Text="{x:Bind}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <Button x:Uid="ResetSettingsToDefaultsButton"
                                Click="{x:Bind ViewModel.ResetToDefaultsAsync}">
                            <Button.ContentTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7A6;" FontSize="16"/>
                                        <TextBlock Text="{x:Bind}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </CCToolKit:WrapPanel>

                </Border>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           x:Uid="SettingsBackupRestoreCurrentValuesSectionHeader" />

                <Border Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       FontWeight="SemiBold"
                                       x:Uid="SettingNameColumnHeaderTextBlock" />
                            <TextBlock Grid.Column="1"
                                       FontWeight="SemiBold"
                                       x:Uid="SettingValueColumnHeaderTextBlock" />
                            <TextBlock Grid.Column="2"
                                       FontWeight="SemiBold"
                                       x:Uid="SettingAcceptedFormatColumnHeaderTextBlock" />
                        </Grid>

                        <ItemsControl ItemsSource="{x:Bind ViewModel.SettingsItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="settingsData:AppSettingDisplayItem">
                                    <Border Padding="0,8"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="3*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Name}"
                                                       IsTextSelectionEnabled="True"
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind CurrentValue}"
                                                       IsTextSelectionEnabled="True"
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind AcceptedFormat}"
                                                       IsTextSelectionEnabled="True"
                                                       TextWrapping="WrapWholeWords" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
