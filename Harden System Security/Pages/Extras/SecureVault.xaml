<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HardenSystemSecurity.Pages.Extras.SecureVault"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:HardenSystemSecurity.Pages.Extras"
      xmlns:CommonCore="using:CommonCore"
      xmlns:CCToolKit="using:CommonCore.ToolKits"
      xmlns:commonBrush="using:CommonCore.UI.Brush"
      xmlns:customUI="using:AppControlManager.CustomUIElements"
      KeyboardAcceleratorPlacementMode="Hidden"
      FlowDirection="{x:Bind CommonCore:Atlas.Settings.ApplicationGlobalFlowDirection, Mode=OneWay}"
      Unloaded="{x:Bind Unloaded_Handler}"
      Loaded="{x:Bind Loaded_Handler}">
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="L"
                             Modifiers="Control"
                             Invoked="{x:Bind LockVaultKeyboardAccelerator_Invoked}" />
    </Page.KeyboardAccelerators>
    <Grid>
        <Grid x:Name="VaultContentPanel"
              Padding="{x:Bind LockedBackgroundContentPadding, Mode=OneWay}"
              RowSpacing="8"
              Opacity="0.10"
              IsHitTestVisible="{x:Bind VaultContentIsHitTestVisible, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <customUI:InfoBarV2 Grid.Row="0"
                                Message="{x:Bind MainInfoBar.Message, Mode=OneWay}"
                                IsIconVisible="True"
                                IsOpen="{x:Bind MainInfoBar.IsOpen, Mode=TwoWay}"
                                IsClosable="{x:Bind MainInfoBar.IsClosable, Mode=OneWay}"
                                Severity="{x:Bind MainInfoBar.Severity, Mode=OneWay}" />
            <Grid Grid.Row="1"
                  ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Uid="SecureVaultPasteTotpTextBlock"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ToggleButton x:Uid="SecureVaultManualEntryToggleButton"
                              Grid.Column="1"
                              MinWidth="90"
                              Padding="10,4"
                              VerticalAlignment="Center"
                              IsChecked="{x:Bind IsManualTotpEntryMode, Mode=TwoWay}">
                    <ToggleButton.ContentTemplate>
                        <DataTemplate x:DataType="x:String">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE70F;" FontSize="16" />
                                <TextBlock Text="{x:Bind}" />
                            </StackPanel>
                        </DataTemplate>
                    </ToggleButton.ContentTemplate>
                </ToggleButton>
                <Button x:Uid="SecureVaultVaultActionsButton"
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <Button.Content>
                        <FontIcon FontSize="16"
                                  Glyph="&#xE712;" />
                    </Button.Content>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="SecureVaultLockVaultMenuFlyoutItem"
                                            Click="{x:Bind LockVault}"
                                            IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}">
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="L"
                                                         Modifiers="Control" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE72E;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="SecureVaultDeleteCurrentVaultMenuFlyoutItem"
                                            Click="{x:Bind DeleteCurrentVault}"
                                            Visibility="{x:Bind DeleteVaultMenuItemVisibility, Mode=OneWay}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="SecureVaultOpenWindowsDateAndTimeSettingsMenuFlyoutItem"
                                            Click="{x:Bind OpenWindowsDateAndTimeSettings}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE713;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="SecureVaultVaultLocationMenuFlyoutItem"
                                            Click="{x:Bind ShowVaultLocationDialog_UI}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="SecureVaultChangeVaultPasswordMenuFlyoutItem"
                                            Click="{x:Bind ChangeVaultPassword}"
                                            IsEnabled="{x:Bind IsChangeVaultPasswordButtonEnabled, Mode=OneWay}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8D7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <ToggleMenuFlyoutItem x:Uid="SecureVaultAutoLockAfterOneMinuteToggleMenuFlyoutItem"
                                                  IsChecked="{x:Bind IsAutoLockAfterOneMinuteEnabled, Mode=TwoWay}">
                                <ToggleMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE72E;" />
                                </ToggleMenuFlyoutItem.Icon>
                            </ToggleMenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>
            <TextBox x:Uid="SecureVaultPasteInputTextBox"
                     Grid.Row="2"
                     x:Name="PasteInputTextBox"
                     AcceptsReturn="True"
                     IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}"
                     IsSpellCheckEnabled="False"
                     PreviewKeyDown="{x:Bind PasteInputTextBox_PreviewKeyDown}"
                     TextChanged="{x:Bind PasteInputTextBox_TextChanged}"
                     MaxHeight="130"
                     TextWrapping="Wrap"
                     Visibility="{x:Bind GetVisibleWhenFalse(IsManualTotpEntryMode), Mode=OneWay}" />
            <StackPanel Grid.Row="3"
                        Spacing="8"
                        Visibility="{x:Bind GetVisibleWhenTrue(IsManualTotpEntryMode), Mode=OneWay}">
                <TextBox x:Uid="SecureVaultManualSecretTextBox"
                         x:Name="ManualSecretTextBox"
                         IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}"
                         IsSpellCheckEnabled="False"
                         PreviewKeyDown="{x:Bind ManualTotpInputTextBox_PreviewKeyDown}"
                         TextChanged="{x:Bind ManualSecretTextBox_TextChanged}" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Uid="SecureVaultManualWebsiteTextBox"
                             Grid.Column="0"
                             IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}"
                             PreviewKeyDown="{x:Bind ManualTotpInputTextBox_PreviewKeyDown}"
                             Text="{x:Bind ManualWebsiteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox x:Uid="SecureVaultManualAccountTextBox"
                             Grid.Column="1"
                             IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}"
                             PreviewKeyDown="{x:Bind ManualTotpInputTextBox_PreviewKeyDown}"
                             Text="{x:Bind ManualAccountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBox x:Uid="SecureVaultManualIssuerTextBox"
                         IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}"
                         PreviewKeyDown="{x:Bind ManualTotpInputTextBox_PreviewKeyDown}"
                         Text="{x:Bind ManualIssuerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button x:Uid="SecureVaultAddTokenButton"
                        HorizontalAlignment="Right"
                        Click="{x:Bind AddCurrentTotpInput}"
                        IsEnabled="{x:Bind IsCurrentTotpInputAddEnabled, Mode=OneWay}">
                    <Button.ContentTemplate>
                        <DataTemplate x:DataType="x:String">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="16" />
                                <TextBlock Text="{x:Bind}" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
            <Grid Grid.Row="4"
                  ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox x:Uid="SecureVaultTokenSearchBox"
                         Grid.Column="0"
                         x:Name="TokenSearchBox"
                         Width="220"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}"
                         Text="{x:Bind SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Border Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Padding="10,6"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8A9;"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock VerticalAlignment="Center">
                            <Run x:Uid="TotalText" />
                            <Run Text="{x:Bind FilteredTokens.Count, Mode=OneWay}"
                                 FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Button x:Uid="SecureVaultTokenActionsButton"
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <Button.Content>
                        <FontIcon FontSize="16"
                                  Glyph="&#xE712;" />
                    </Button.Content>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="SecureVaultClearAllTokensMenuFlyoutItem"
                                            Click="{x:Bind ClearAllTokens}"
                                            IsEnabled="{x:Bind IsVaultUnlocked, Mode=OneWay}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="SecureVaultAddAllTokensMenuFlyoutItem"
                                            Click="{x:Bind AddPastedTotpEntries}"
                                            IsEnabled="{x:Bind IsAddButtonEnabled, Mode=OneWay}"
                                            Visibility="{x:Bind GetVisibleWhenFalse(IsManualTotpEntryMode), Mode=OneWay}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE710;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="SecureVaultAddTokenMenuFlyoutItem"
                                            Click="{x:Bind AddCurrentTotpInput}"
                                            IsEnabled="{x:Bind IsCurrentTotpInputAddEnabled, Mode=OneWay}"
                                            Visibility="{x:Bind GetVisibleWhenTrue(IsManualTotpEntryMode), Mode=OneWay}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE710;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>
            <ListView Grid.Row="5"
                      ItemsSource="{x:Bind FilteredTokens, Mode=OneWay}"
                      SelectionMode="None"
                      Visibility="{x:Bind TokenListVisibility, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TotpTokenItem">
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ProgressRing Grid.Column="0"
                                              Width="44"
                                              Height="44"
                                              IsIndeterminate="False"
                                              Maximum="{x:Bind PeriodSeconds, Mode=OneWay}"
                                              Value="{x:Bind ElapsedSeconds, Mode=OneWay}" />
                                <StackPanel Grid.Column="1"
                                            Spacing="4">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   Text="{x:Bind DisplayName, Mode=OneWay}"
                                                   TextWrapping="WrapWholeWords" />
                                        <Button x:Uid="SecureVaultShowTokenNotesButton"
                                                Grid.Column="1"
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Click="ShowTotpTokenNotes_Click"
                                                Tag="{x:Bind}"
                                                Visibility="{x:Bind NotesPreviewButtonVisibility, Mode=OneWay}">
                                            <FontIcon FontSize="14"
                                                      Glyph="&#xE70B;" />
                                        </Button>
                                    </Grid>
                                    <TextBlock FontSize="30"
                                               FontWeight="SemiBold"
                                               IsTextSelectionEnabled="True"
                                               Text="{x:Bind Code, Mode=OneWay}" />
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Text="{x:Bind RemainingText, Mode=OneWay}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            MinWidth="86"
                                            Spacing="8">
                                    <Button HorizontalAlignment="Stretch"
                                            x:Uid="CopyButton"
                                            Click="CopyTotpCode_Click"
                                            Tag="{x:Bind}">
                                        <Button.ContentTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8C8;" FontSize="16" />
                                                    <TextBlock Text="{x:Bind}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>
                                    <Button x:Uid="SecureVaultEditTotpTokenNotesButton"
                                            HorizontalAlignment="Stretch"
                                            Click="EditTotpTokenNotes_Click"
                                            Tag="{x:Bind}">
                                        <StackPanel HorizontalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Spacing="6">
                                            <FontIcon FontSize="14"
                                                      Glyph="&#xE70B;" />
                                            <TextBlock Text="{x:Bind NotesActionText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Uid="SecureVaultRemoveTotpTokenButton"
                                            HorizontalAlignment="Stretch"
                                            Click="RemoveTotpToken_Click"
                                            Tag="{x:Bind}">
                                        <Button.ContentTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                                    <TextBlock Text="{x:Bind}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <Border x:Name="VaultLockedOverlay"
                IsHitTestVisible="{x:Bind VaultLockedOverlayHitTestVisible, Mode=OneWay}">
            <Border.Background>
                <commonBrush:BackdropBlurBrush Amount="3"
                                               TintColor="Black"
                                               TintOpacity="0" />
            </Border.Background>
            <Grid Padding="18">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="380"
                        MaxWidth="420"
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0"
                                      FontSize="20"
                                      Glyph="&#xE72E;" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       Text="{x:Bind LockedStateCardTitle, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>
                        <customUI:InfoBarV2 Message="{x:Bind LockedInfoBar.Message, Mode=OneWay}"
                                            IsIconVisible="False"
                                            IsOpen="{x:Bind LockedInfoBar.IsOpen, Mode=TwoWay}"
                                            IsClosable="{x:Bind LockedInfoBar.IsClosable, Mode=OneWay}"
                                            Severity="{x:Bind LockedInfoBar.Severity, Mode=OneWay}" />
                        <StackPanel Spacing="10"
                                    Visibility="{x:Bind CreateVaultSectionVisibility, Mode=OneWay}">
                            <StackPanel Spacing="6">
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Text="{x:Bind NewVaultPasswordStrengthText, Mode=OneWay}"
                                           TextWrapping="WrapWholeWords" />
                                <ProgressBar Minimum="0"
                                             Maximum="{x:Bind PasswordStrengthMaximum, Mode=OneWay}"
                                             Foreground="{x:Bind NewVaultPasswordStrengthBrush, Mode=OneWay}"
                                             Value="{x:Bind NewVaultPasswordStrengthValue, Mode=OneWay}" />
                            </StackPanel>
                            <PasswordBox x:Uid="SecureVaultNewVaultPasswordBox"
                                         x:Name="NewVaultPasswordBox"
                                         PasswordRevealMode="Peek"
                                         PasswordChanged="{x:Bind NewVaultPasswordBox_PasswordChanged}"
                                         KeyDown="{x:Bind NewVaultPasswordBox_KeyDown}" />
                            <PasswordBox x:Uid="SecureVaultConfirmNewVaultPasswordBox"
                                         x:Name="ConfirmNewVaultPasswordBox"
                                         PasswordRevealMode="Peek"
                                         KeyDown="{x:Bind NewVaultPasswordBox_KeyDown}" />
                            <CCToolKit:WrapPanel Orientation="Horizontal" HorizontalSpacing="10">
                                <Button x:Uid="SecureVaultCreateNewVaultButton"
                                        Click="{x:Bind CreateNewVault}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE710;" FontSize="16" />
                                                <TextBlock Text="{x:Bind}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="SecureVaultImportVaultOverlayButton"
                                        Click="{x:Bind ImportVaultJsonFile}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE898;" FontSize="16" />
                                                <TextBlock Text="{x:Bind}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                            </CCToolKit:WrapPanel>
                        </StackPanel>
                        <StackPanel Spacing="10"
                                    Visibility="{x:Bind UnlockVaultSectionVisibility, Mode=OneWay}">
                            <PasswordBox x:Uid="SecureVaultUnlockVaultPasswordBox"
                                         x:Name="UnlockVaultPasswordBox"
                                         PasswordRevealMode="Peek"
                                         KeyDown="{x:Bind UnlockVaultPasswordBox_KeyDown}" />
                            <CCToolKit:WrapPanel Orientation="Horizontal"
                                                 VerticalSpacing="8"
                                                 HorizontalSpacing="8">
                                <Button x:Uid="SecureVaultUnlockWithPasswordButton"
                                        Click="{x:Bind UnlockWithPassword}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE785;" FontSize="16" />
                                                <TextBlock Text="{x:Bind}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="SecureVaultDeleteCurrentVaultOverlayButton"
                                        Click="{x:Bind DeleteCurrentVault}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                                <TextBlock Text="{x:Bind}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                            </CCToolKit:WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
