<customUI:ContentDialogV2
    x:Class="AppControlManager.CustomUIElements.SystemShutdownInfoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    xmlns:VMs="using:AppControlManager.ViewModels"
    xmlns:CCore="using:CommonCore.Others"
    Title="Shutdown Info"
    Loaded="{x:Bind ViewModel.GenerateData}"
    PrimaryButtonText="Close"
    DefaultButton="Primary">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Bar Controls -->
        <CCToolKit:WrapPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,10"
                            HorizontalSpacing="8"
                            VerticalSpacing="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">

            <!-- Counts card -->
            <Border CornerRadius="8"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Padding="10,6"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8A9;" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock VerticalAlignment="Center">
                        <Run x:Uid="TotalText" />
                        <Run Text="{x:Bind ViewModel.ShutDownInfoSource.Count, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
            </Border>

        </CCToolKit:WrapPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.ShutDownInfoSource}"
                  SelectionMode="None"
                  ScrollViewer.HorizontalScrollMode="Enabled"
                  ScrollViewer.IsHorizontalRailEnabled="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Visible"
                  ShowsScrollingPlaceholders="True"
                  ScrollViewer.VerticalScrollBarVisibility="Visible">

            <ListView.Header>
                <Border CornerRadius="5" Background="Black" customUI:StickyHeaderBehaviorV2.IsEnabled="True">
                    <Grid Padding="5">
                        <Grid.ColumnDefinitions>
                            <!-- Binding Mode must be TwoWay for resizing to work from UI back to ViewModel. Binding to .Width property prevents CollectionChanged re-entrancy. -->
                            <ColumnDefinition Width="{x:Bind ViewModel.ColumnManager.ColumnWidths[0].Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ColumnManager.ColumnWidths[1].Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ColumnManager.ColumnWidths[2].Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ColumnManager.ColumnWidths[3].Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ColumnManager.ColumnWidths[4].Width, Mode=TwoWay}" />
                        </Grid.ColumnDefinitions>

                        <!-- Sortable Headers -->
                        <Button Content="Time" Tag="Time" Grid.Column="0" Background="Transparent" Foreground="LightGray" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" BorderThickness="0" />
                        <Button Content="Type" Tag="Type" Grid.Column="1" Background="Transparent" Foreground="LightGray" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" BorderThickness="0" />
                        <Button Content="Reason" Tag="Reason" Grid.Column="2" Background="Transparent" Foreground="LightGray" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" BorderThickness="0"/>
                        <Button Content="User" Tag="User" Grid.Column="3" Background="Transparent" Foreground="LightGray" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" BorderThickness="0" />
                        <Button Content="Program" Tag="Program" Grid.Column="4" Background="Transparent" Foreground="LightGray" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" BorderThickness="0" />
                    </Grid>
                </Border>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="CCore:ShutDownInfo">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{x:Bind VMs:ViewModelProvider.SystemShutdownInfoDialogVM.ColumnManager.ColumnWidths[0].Width, Mode=OneWay}" />
                            <ColumnDefinition Width="{x:Bind VMs:ViewModelProvider.SystemShutdownInfoDialogVM.ColumnManager.ColumnWidths[1].Width, Mode=OneWay}" />
                            <ColumnDefinition Width="{x:Bind VMs:ViewModelProvider.SystemShutdownInfoDialogVM.ColumnManager.ColumnWidths[2].Width, Mode=OneWay}" />
                            <ColumnDefinition Width="{x:Bind VMs:ViewModelProvider.SystemShutdownInfoDialogVM.ColumnManager.ColumnWidths[3].Width, Mode=OneWay}" />
                            <ColumnDefinition Width="{x:Bind VMs:ViewModelProvider.SystemShutdownInfoDialogVM.ColumnManager.ColumnWidths[4].Width, Mode=OneWay}" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind Time}" Grid.Column="0" VerticalAlignment="Center" Margin="5,10,5,10" IsTextSelectionEnabled="True"/>
                        <TextBlock Text="{x:Bind Type}" Grid.Column="1" VerticalAlignment="Center" Margin="5,10,5,10" IsTextSelectionEnabled="True"/>
                        <TextBlock Text="{x:Bind Reason}" Grid.Column="2" VerticalAlignment="Center" Margin="5,10,5,10" IsTextSelectionEnabled="True"/>
                        <TextBlock Text="{x:Bind User}" Grid.Column="3" VerticalAlignment="Center" Margin="5,10,5,10" IsTextSelectionEnabled="True"/>
                        <TextBlock Text="{x:Bind Program}" Grid.Column="4" VerticalAlignment="Center" Margin="5,10,5,10" IsTextSelectionEnabled="True"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</customUI:ContentDialogV2>