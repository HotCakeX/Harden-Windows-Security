                        <FontIcon Glyph="&#xE7B8;" />
                    </SelectorBarItem.Icon>
                </SelectorBarItem>
                <SelectorBarItem x:Uid="WinGetAppBundlesSelectorBarItem" x:Name="BundlesSectionSelectorBarItem">
                    <SelectorBarItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </SelectorBarItem.Icon>
                </SelectorBarItem>
                <SelectorBarItem x:Uid="WinGetSourcesSelectorBarItem" x:Name="SourcesSectionSelectorBarItem" IsEnabled="{x:Bind commonCore:Atlas.IsElevated}">
                    <SelectorBarItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </SelectorBarItem.Icon>
                </SelectorBarItem>
            </SelectorBar>
            <Button x:Uid="WinGetSearchSettingsButton"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="{x:Bind ViewModel.ToggleSettingsPane}">
                <FontIcon Glyph="&#xE713;" />
            </Button>
        </Grid>
        <SplitView Grid.Row="2"
                   IsPaneOpen="{x:Bind ViewModel.IsWinGetSettingsPaneOpen, Mode=TwoWay}"
                   DisplayMode="Inline"
                   OpenPaneLength="360"
                   PanePlacement="Right"
                   PaneBackground="Transparent">
            <SplitView.Pane>
                <Border Padding="16"
                        BorderThickness="1,0,0,0"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12">
                            <TextBlock x:Uid="WinGetSearchSettingsHeaderTextBlock"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <StackPanel Spacing="2">
                                <TextBlock x:Uid="WinGetEngineVersionTextBlock"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.WinGetEngineVersion, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True" />
                            </StackPanel>
                            <TextBlock x:Uid="WinGetSearchDownloadDirectoryDescriptionTextBlock"
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource BodyTextBlockStyle}" />
                            <TextBox x:Uid="WinGetSearchDownloadDirectoryTextBox"
                                     Text="{x:Bind ViewModel.ResolvedDownloadDirectory, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap" />
                            <Button x:Uid="WinGetSearchBrowseDownloadDirectoryButton"
                                    Click="{x:Bind ViewModel.BrowseDownloadDirectory}" />
                            <Button x:Uid="WinGetSearchResetDownloadDirectoryButton"
                                    IsEnabled="{x:Bind ViewModel.CanResetDownloadDirectory, Mode=OneWay}"
                                    Click="{x:Bind ViewModel.ResetDownloadDirectory}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </SplitView.Pane>
            <SplitView.Content>
                <Grid>
                    <!--Searching for new packages-->
                    <Grid x:Name="SearchSectionGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Padding="18"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <toolkits:WrapPanel Orientation="Horizontal"
                                                    HorizontalSpacing="8"
                                                    VerticalSpacing="8">
                                <TextBox x:Uid="WinGetPackageSearchTextBox"
                                             Width="320"
                                             VerticalAlignment="Center"
                                             Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                             KeyDown="{x:Bind ViewModel.PackageSearchTextBox_KeyDown}" />
                                <SplitButton x:Uid="WinGetSearchButton"
                                                 VerticalAlignment="Center"
                                                 IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                                 Click="{x:Bind ViewModel.SearchPackagesAsync}">
                                    <SplitButton.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE721;" FontSize="16" />
                                                <TextBlock Text="{x:Bind}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </SplitButton.ContentTemplate>
                                    <SplitButton.Flyout>
                                        <Flyout>
                                            <StackPanel Width="280" Spacing="12">
                                                <TextBlock x:Uid="WinGetSearchFieldTextBlock"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <ComboBox HorizontalAlignment="Stretch"
                                                              ItemsSource="{x:Bind ViewModel.PackageSearchFieldOptions, Mode=OneWay}"
                                                              IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                                              SelectedIndex="{x:Bind ViewModel.SelectedPackageSearchFieldValue, Mode=TwoWay}" />
                                                <TextBlock x:Uid="SourceHeader"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <ComboBox HorizontalAlignment="Stretch"
                                                              ItemsSource="{x:Bind ViewModel.PackageSearchSourceOptions, Mode=OneWay}"
                                                              IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                                              SelectedIndex="{x:Bind ViewModel.SelectedPackageSearchSourceValue, Mode=TwoWay}" />
                                                <TextBlock x:Uid="WinGetMatchModeTextBlock"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <ComboBox HorizontalAlignment="Stretch"
                                                              ItemsSource="{x:Bind ViewModel.PackageSearchMatchModeOptions, Mode=OneWay}"
                                                              IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                                              SelectedIndex="{x:Bind ViewModel.SelectedPackageSearchMatchModeValue, Mode=TwoWay}" />
                                                <TextBlock x:Uid="WinGetSearchResultLimitTextBlock"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <NumberBox Value="{x:Bind ViewModel.SearchResultLimitValue, Mode=TwoWay}"
                                                           Minimum="1"
                                                           Maximum="100"
                                                           SmallChange="1"
                                                           LargeChange="10"
                                                           SpinButtonPlacementMode="Inline"
                                                           ValidationMode="InvalidInputOverwritten"
                                                           ValueChanged="{x:Bind ViewModel.SearchResultLimitNumberBox_ValueChanged}"
                                                           IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}" />
                                            </StackPanel>
                                        </Flyout>
                                    </SplitButton.Flyout>
                                </SplitButton>
                                <Button x:Uid="WinGetSearchClearButton"
                                            VerticalAlignment="Center"
                                            IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                            Click="{x:Bind ViewModel.ClearSearchResults}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xED62;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="ExportToJsonButton"
                                            VerticalAlignment="Center"
                                            IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                            Click="{x:Bind ViewModel.ExportSearchResultsToJson_Click}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="WinGetCancelButton"
                                            VerticalAlignment="Center"
                                            IsEnabled="{x:Bind ViewModel.IsSearchCancelButtonEnabled, Mode=OneWay}"
                                            Click="{x:Bind ViewModel.CancelCurrentSearch}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="WinGetSearchResultsBulkActionsButton" MinWidth="36"
                                            MinHeight="36"
                                            Padding="6"
                                            IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE712;" />
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <SplitMenuFlyoutItem x:Uid="WinGetInstallOrUpdateSelectedMenuFlyoutItem"
                                                             Click="{x:Bind ViewModel.InstallOrUpdateSelectedSearchResults_Click}">
                                                <SplitMenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xEDAB;" />
                                                </SplitMenuFlyoutItem.Icon>
                                                <SplitMenuFlyoutItem x:Uid="WinGetSilentMenuFlyoutItem"
                                                                 Click="{x:Bind ViewModel.InstallOrUpdateSelectedSearchResultsSilent_Click}">
                                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                Click="{x:Bind ViewModel.InstallOrUpdateSelectedSearchResultsSilentUser_Click}" />
                                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                Click="{x:Bind ViewModel.InstallOrUpdateSelectedSearchResultsSilentMachine_Click}" />
                                                </SplitMenuFlyoutItem>
                                                <SplitMenuFlyoutItem x:Uid="WinGetInteractiveMenuFlyoutItem"
                                                                 Click="{x:Bind ViewModel.InstallOrUpdateSelectedSearchResultsInteractive_Click}">
                                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                Click="{x:Bind ViewModel.InstallOrUpdateSelectedSearchResultsInteractiveUser_Click}" />
                                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                Click="{x:Bind ViewModel.InstallOrUpdateSelectedSearchResultsInteractiveMachine_Click}" />
                                                </SplitMenuFlyoutItem>
                                            </SplitMenuFlyoutItem>
                                            <MenuFlyoutItem x:Uid="WinGetDownloadSelectedMenuFlyoutItem"
                                                                Click="{x:Bind ViewModel.DownloadSelectedSearchResults_Click}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE896;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem x:Uid="WinGetRefreshSelectedStatusMenuFlyoutItem"
                                                                Click="{x:Bind ViewModel.RefreshSelectedSearchResultsStatus_Click}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE72C;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                <Button x:Uid="WinGetSelectAllSearchResultsButton" MinWidth="36"
                                            MinHeight="36"
                                            Padding="6"
                                            IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                            Click="{x:Bind ViewModel.SelectAllSearchResults_Click}">
                                    <SymbolIcon Symbol="SelectAll" />
                                </Button>
                                <Button x:Uid="WinGetDeselectAllSearchResultsButton" MinWidth="36"
                                            MinHeight="36"
                                            Padding="6"
                                            IsEnabled="{x:Bind ViewModel.SearchPackageUIElementsAreEnabled, Mode=OneWay}"
                                            Click="{x:Bind ViewModel.DeselectAllSearchResults_Click}">
                                    <FontIcon Glyph="&#xE8E6;" />
                                </Button>
                                <ProgressRing IsActive="True"
                                                  Visibility="{x:Bind ViewModel.SearchProgressRingVisibility, Mode=OneWay}" />
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="12"
                                            Padding="12,8">
                                    <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                            <Run Text="Items: " />
                                            <Run Text="{x:Bind ViewModel.SearchResultsCount, Mode=OneWay}" />
                                            <Run Text=" | Selected: " />
                                            <Run Text="{x:Bind ViewModel.SelectedSearchResultsCount, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                            </toolkits:WrapPanel>
                        </Border>
                        <customUI:ListViewV2 Grid.Row="1"
                                             RegistryKey="WinGet_SearchResults"
                                             ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                                             ItemTemplate="{StaticResource WinGetPackageSearchTemplate}"
                                             SelectionMode="Multiple"
                                             SelectionChanged="{x:Bind ViewModel.SearchResultsListView_SelectionChanged}"
                                             ScrollViewer.HorizontalScrollMode="Disabled"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>

                    <!--Installed Programs-->
                    <Grid x:Name="InstalledProgramsSectionGrid" RowSpacing="16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Padding="18"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <toolkits:WrapPanel Grid.Row="0"
                                                Orientation="Horizontal"
                                                HorizontalSpacing="8"
                                                VerticalSpacing="8">
                                <Button x:Uid="WinGetRefreshInstalledProgramsButton"
                                        IsEnabled="{x:Bind ViewModel.InstalledProgramsUIElementsAreEnabled, Mode=OneWay}"
                                        Click="{x:Bind ViewModel.LoadInstalledPrograms}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="ExportToJsonButton"
                                        IsEnabled="{x:Bind ViewModel.InstalledProgramsUIElementsAreEnabled, Mode=OneWay}"
                                        Click="{x:Bind ViewModel.ExportInstalledProgramsToJson_Click}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <ToggleButton x:Uid="WinGetUpdatesOnlyToggleButton"
                                        IsChecked="{x:Bind ViewModel.ShowOnlyInstalledProgramsWithUpdates, Mode=TwoWay}"
                                        IsEnabled="{x:Bind ViewModel.InstalledProgramsUIElementsAreEnabled, Mode=OneWay}">
                                    <ToggleButton.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE895;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ToggleButton.ContentTemplate>
                                </ToggleButton>
                                <Button x:Uid="WinGetCancelButton"
                                        IsEnabled="{x:Bind ViewModel.IsInstalledProgramsCancelButtonEnabled, Mode=OneWay}"
                                        Click="{x:Bind ViewModel.CancelInstalledQuery}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="WinGetInstalledProgramsBulkActionsButton" MinWidth="36"
                                        MinHeight="36"
                                        Padding="6"
                                        IsEnabled="{x:Bind ViewModel.InstalledProgramsUIElementsAreEnabled, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE712;" />
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <SplitMenuFlyoutItem x:Uid="WinGetUpdateOrReinstallSelectedMenuFlyoutItem"
                                                                 Click="{x:Bind ViewModel.UpdateOrReinstallSelectedInstalledPrograms_Click}">
                                                <SplitMenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xEDAB;" />
                                                </SplitMenuFlyoutItem.Icon>
                                                <SplitMenuFlyoutItem x:Uid="WinGetSilentMenuFlyoutItem"
                                                                     Click="{x:Bind ViewModel.UpdateOrReinstallSelectedInstalledProgramsSilent_Click}">
                                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                    Click="{x:Bind ViewModel.UpdateOrReinstallSelectedInstalledProgramsSilentUser_Click}" />
                                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                    IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                    Click="{x:Bind ViewModel.UpdateOrReinstallSelectedInstalledProgramsSilentMachine_Click}" />
                                                </SplitMenuFlyoutItem>
                                                <SplitMenuFlyoutItem x:Uid="WinGetInteractiveMenuFlyoutItem"
                                                                     Click="{x:Bind ViewModel.UpdateOrReinstallSelectedInstalledProgramsInteractive_Click}">
                                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                    Click="{x:Bind ViewModel.UpdateOrReinstallSelectedInstalledProgramsInteractiveUser_Click}" />
                                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                    IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                    Click="{x:Bind ViewModel.UpdateOrReinstallSelectedInstalledProgramsInteractiveMachine_Click}" />
                                                </SplitMenuFlyoutItem>
                                            </SplitMenuFlyoutItem>
                                            <MenuFlyoutItem x:Uid="WinGetDownloadSelectedMenuFlyoutItem"
                                                            Click="{x:Bind ViewModel.DownloadSelectedInstalledPrograms_Click}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE896;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem x:Uid="WinGetRepairSelectedMenuFlyoutItem"
                                                            Click="{x:Bind ViewModel.RepairSelectedInstalledPrograms_Click}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE90F;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <SplitMenuFlyoutItem x:Uid="WinGetUninstallSelectedMenuFlyoutItem"
                                                                 Click="{x:Bind ViewModel.UninstallSelectedInstalledPrograms_Click}">
                                                <SplitMenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xEC91;" />
                                                </SplitMenuFlyoutItem.Icon>
                                                <SplitMenuFlyoutItem x:Uid="WinGetSilentMenuFlyoutItem"
                                                                     Click="{x:Bind ViewModel.UninstallSelectedInstalledProgramsSilent_Click}">
                                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                    Click="{x:Bind ViewModel.UninstallSelectedInstalledProgramsSilentUser_Click}" />
                                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                    IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                    Click="{x:Bind ViewModel.UninstallSelectedInstalledProgramsSilentMachine_Click}" />
                                                </SplitMenuFlyoutItem>
                                                <SplitMenuFlyoutItem x:Uid="WinGetInteractiveMenuFlyoutItem"
                                                                     Click="{x:Bind ViewModel.UninstallSelectedInstalledProgramsInteractive_Click}">
                                                    <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                    Click="{x:Bind ViewModel.UninstallSelectedInstalledProgramsInteractiveUser_Click}" />
                                                    <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                    IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                    Click="{x:Bind ViewModel.UninstallSelectedInstalledProgramsInteractiveMachine_Click}" />
                                                </SplitMenuFlyoutItem>
                                            </SplitMenuFlyoutItem>
                                            <MenuFlyoutItem x:Uid="WinGetRefreshSelectedStatusMenuFlyoutItem"
                                                            Click="{x:Bind ViewModel.RefreshSelectedInstalledProgramsStatus_Click}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE72C;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                <Button x:Uid="WinGetSelectAllInstalledProgramsButton" MinWidth="36"
                                        MinHeight="36"
                                        Padding="6"
                                        IsEnabled="{x:Bind ViewModel.InstalledProgramsUIElementsAreEnabled, Mode=OneWay}"
                                        Click="{x:Bind ViewModel.SelectAllInstalledPrograms_Click}">
                                    <SymbolIcon Symbol="SelectAll" />
                                </Button>
                                <Button x:Uid="WinGetDeselectAllInstalledProgramsButton" MinWidth="36"
                                        MinHeight="36"
                                        Padding="6"
                                        IsEnabled="{x:Bind ViewModel.InstalledProgramsUIElementsAreEnabled, Mode=OneWay}"
                                        Click="{x:Bind ViewModel.DeselectAllInstalledPrograms_Click}">
                                    <FontIcon Glyph="&#xE8E6;" />
                                </Button>
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="12"
                                        Padding="12,8">
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <Run Text="Items: " />
                                        <Run Text="{x:Bind ViewModel.InstalledProgramsCount, Mode=OneWay}" />
                                        <Run Text=" of " />
                                        <Run Text="{x:Bind ViewModel.InstalledProgramsTotalCount, Mode=OneWay}" />
                                        <Run Text=" | Selected: " />
                                        <Run Text="{x:Bind ViewModel.SelectedInstalledProgramsCount, Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                                <TextBox x:Uid="WinGetInstalledProgramsSearchTextBox"
                                         Text="{x:Bind ViewModel.InstalledProgramsSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{x:Bind ViewModel.InstalledProgramsUIElementsAreEnabled, Mode=OneWay}" />
                                <ProgressRing IsActive="True"
                                              Visibility="{x:Bind ViewModel.InstalledProgramsProgressRingVisibility, Mode=OneWay}" />
                            </toolkits:WrapPanel>
                        </Border>
                        <customUI:ListViewV2 Grid.Row="1"
                                             RegistryKey="WinGet_InstalledPackages"
                                             ItemsSource="{x:Bind ViewModel.InstalledPrograms, Mode=OneWay}"
                                             ItemTemplate="{StaticResource WinGetPackageTemplate}"
                                             SelectionMode="Multiple"
                                             SelectionChanged="{x:Bind ViewModel.InstalledProgramsListView_SelectionChanged}"
                                             ScrollViewer.HorizontalScrollMode="Disabled"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>
                    <!--App Bundles-->
                    <Grid x:Name="BundlesSectionGrid" Visibility="Collapsed">
                        <Grid x:Name="BundleTilesGrid"
                              Opacity="1"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <CompositeTransform x:Name="BundleTilesTransform" />
                            </Grid.RenderTransform>
                            <GridView ItemsSource="{x:Bind ViewModel.PackageBundles}"
                                      ItemTemplate="{StaticResource WinGetBundleTileTemplate}"
                                      IsItemClickEnabled="True"
                                      ItemClick="{x:Bind BundleGridView_ItemClick}"
                                      SelectionMode="None"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <GridView.ItemContainerTransitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                                        <RepositionThemeTransition />
                                    </TransitionCollection>
                                </GridView.ItemContainerTransitions>
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal"
                                                       ItemWidth="270"
                                                       ItemHeight="244" />
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                            </GridView>
                        </Grid>
                        <Grid x:Name="BundleOverlayGrid"
                              Padding="28"
                              Opacity="0"
                              Visibility="Collapsed"
                              IsHitTestVisible="False">
                            <Border CornerRadius="24"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <CompositeTransform x:Name="BundleOverlayContentTransform"
                                                        ScaleX="0.72"
                                                        ScaleY="0.72"
                                                        TranslateY="86"
                                                        Rotation="6.8" />
                                </Border.RenderTransform>
                                <Grid>
                                    <Border x:Name="BundleTransitionLayer"
                                            CornerRadius="24"
                                            IsHitTestVisible="False"
                                            Opacity="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    CornerRadius="24,0,0,24"
                                                    RenderTransformOrigin="1,0.5">
                                                <Border.RenderTransform>
                                                    <CompositeTransform x:Name="BundleTransitionPanelOneTransform" ScaleX="0" />
                                                </Border.RenderTransform>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#A770EF" Offset="0" />
                                                        <GradientStop Color="#CF8BF3" Offset="0.5" />
                                                        <GradientStop Color="#FDB99B" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    RenderTransformOrigin="1,0.5">
                                                <Border.RenderTransform>
                                                    <CompositeTransform x:Name="BundleTransitionPanelTwoTransform" ScaleX="0" />
                                                </Border.RenderTransform>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#A770EF" Offset="0" />
                                                        <GradientStop Color="#CF8BF3" Offset="0.5" />
                                                        <GradientStop Color="#FDB99B" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border Grid.Column="2"
                                                    RenderTransformOrigin="1,0.5">
                                                <Border.RenderTransform>
                                                    <CompositeTransform x:Name="BundleTransitionPanelThreeTransform" ScaleX="0" />
                                                </Border.RenderTransform>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#A770EF" Offset="0" />
                                                        <GradientStop Color="#CF8BF3" Offset="0.5" />
                                                        <GradientStop Color="#FDB99B" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border Grid.Column="3"
                                                    CornerRadius="0,24,24,0"
                                                    RenderTransformOrigin="1,0.5">
                                                <Border.RenderTransform>
                                                    <CompositeTransform x:Name="BundleTransitionPanelFourTransform" ScaleX="0" />
                                                </Border.RenderTransform>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#A770EF" Offset="0" />
                                                        <GradientStop Color="#CF8BF3" Offset="0.5" />
                                                        <GradientStop Color="#FDB99B" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <Grid Padding="24" RowSpacing="22">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <toolkits:WrapPanel x:Name="BundleOverlayToolbar"
                                                            Grid.Row="0"
                                                            Orientation="Horizontal"
                                                            HorizontalSpacing="8"
                                                            VerticalSpacing="8"
                                                            Opacity="0">
                                            <toolkits:WrapPanel.RenderTransform>
                                                <CompositeTransform x:Name="BundleOverlayToolbarTransform"
                                                                    TranslateY="0" />
                                            </toolkits:WrapPanel.RenderTransform>
                                            <Button x:Uid="WinGetBackToBundlesButton" MinWidth="52"
                                                    MinHeight="52"
                                                    Margin="0,0,14,0"
                                                    Padding="10"
                                                    Click="{x:Bind CloseSelectedBundle_Click}">
                                                <FontIcon Glyph="&#xE72B;" FontSize="24" />
                                            </Button>
                                            <StackPanel MinWidth="220"
                                                        MaxWidth="560"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind ViewModel.SelectedPackageBundleTitle, Mode=OneWay}"
                                                           Style="{ThemeResource TitleTextBlockStyle}"
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{x:Bind ViewModel.BundleOperationStatus, Mode=OneWay}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ProgressRing Width="32"
                                                          Height="32"
                                                          IsActive="True"
                                                          Visibility="{x:Bind ViewModel.BundleOperationProgressRingVisibility, Mode=OneWay}" />
                                            <SplitButton x:Uid="WinGetInstallAllSplitButton"
                                                         IsEnabled="{x:Bind ViewModel.BundlesUIElementsAreEnabled, Mode=OneWay}"
                                                         Click="{x:Bind ViewModel.InstallSelectedBundle_Click}">
                                                <SplitButton.ContentTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xEDAB;" FontSize="16" />
                                                            <TextBlock Text="{x:Bind}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </SplitButton.ContentTemplate>
                                                <SplitButton.Flyout>
                                                    <MenuFlyout>
                                                        <SplitMenuFlyoutItem x:Uid="WinGetSilentMenuFlyoutItem"
                                                                             Click="{x:Bind ViewModel.InstallSelectedBundleSilent_Click}">
                                                            <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                            Click="{x:Bind ViewModel.InstallSelectedBundleSilentUser_Click}" />
                                                            <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                            IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                            Click="{x:Bind ViewModel.InstallSelectedBundleSilentMachine_Click}" />
                                                        </SplitMenuFlyoutItem>
                                                        <SplitMenuFlyoutItem x:Uid="WinGetInteractiveMenuFlyoutItem"
                                                                             Click="{x:Bind ViewModel.InstallSelectedBundleInteractive_Click}">
                                                            <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                            Click="{x:Bind ViewModel.InstallSelectedBundleInteractiveUser_Click}" />
                                                            <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                            IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                            Click="{x:Bind ViewModel.InstallSelectedBundleInteractiveMachine_Click}" />
                                                        </SplitMenuFlyoutItem>
                                                    </MenuFlyout>
                                                </SplitButton.Flyout>
                                            </SplitButton>
                                            <SplitButton x:Uid="WinGetUninstallAllSplitButton"
                                                         IsEnabled="{x:Bind ViewModel.BundlesUIElementsAreEnabled, Mode=OneWay}"
                                                         Click="{x:Bind ViewModel.UninstallSelectedBundle_Click}">
                                                <SplitButton.ContentTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xEC91;" FontSize="16" />
                                                            <TextBlock Text="{x:Bind}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </SplitButton.ContentTemplate>
                                                <SplitButton.Flyout>
                                                    <MenuFlyout>
                                                        <SplitMenuFlyoutItem x:Uid="WinGetSilentMenuFlyoutItem"
                                                                             Click="{x:Bind ViewModel.UninstallSelectedBundleSilent_Click}">
                                                            <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                            Click="{x:Bind ViewModel.UninstallSelectedBundleSilentUser_Click}" />
                                                            <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                            IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                            Click="{x:Bind ViewModel.UninstallSelectedBundleSilentMachine_Click}" />
                                                        </SplitMenuFlyoutItem>
                                                        <SplitMenuFlyoutItem x:Uid="WinGetInteractiveMenuFlyoutItem"
                                                                             Click="{x:Bind ViewModel.UninstallSelectedBundleInteractive_Click}">
                                                            <MenuFlyoutItem x:Uid="WinGetCurrentUserMenuFlyoutItem"
                                                                            Click="{x:Bind ViewModel.UninstallSelectedBundleInteractiveUser_Click}" />
                                                            <MenuFlyoutItem x:Uid="WinGetSystemMenuFlyoutItem"
                                                                            IsEnabled="{x:Bind commonCore:Atlas.IsElevated}"
                                                                            Click="{x:Bind ViewModel.UninstallSelectedBundleInteractiveMachine_Click}" />
                                                        </SplitMenuFlyoutItem>
                                                    </MenuFlyout>
                                                </SplitButton.Flyout>
                                            </SplitButton>
                                            <Button x:Uid="WinGetCancelButton"
                                                    IsEnabled="{x:Bind ViewModel.IsBundleOperationCancelButtonEnabled, Mode=OneWay}"
                                                    Click="{x:Bind ViewModel.CancelCurrentBundleOperation}">
                                                <Button.ContentTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE711;" FontSize="16" />
                                                            <TextBlock Text="{x:Bind}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Button.ContentTemplate>
                                            </Button>
                                        </toolkits:WrapPanel>
                                        <GridView x:Name="BundleOverlayAppsGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{x:Bind ViewModel.SelectedPackageBundlePackages, Mode=OneWay}"
                                                  ItemTemplate="{StaticResource WinGetBundleAppTemplate}"
                                                  SelectionMode="None"
                                                  IsItemClickEnabled="False"
                                                  Opacity="0"
                                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <GridView.ItemContainerTransitions>
                                                <TransitionCollection>
                                                    <RepositionThemeTransition />
                                                </TransitionCollection>
                                            </GridView.ItemContainerTransitions>
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal"
                                                                   ItemWidth="178"
                                                                   ItemHeight="190" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                        </GridView>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                    <!--Sources-->
                    <Grid x:Name="SourcesSectionGrid" RowSpacing="16" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Padding="18"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Uid="WinGetSourceNameTextBox" Grid.Column="0"
                                             Text="{x:Bind ViewModel.SourceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}" />
                                <TextBox x:Uid="WinGetSourceArgumentTextBox" Grid.Column="1"
                                             Text="{x:Bind ViewModel.SourceUri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}" />
                                <ComboBox x:Uid="WinGetSourceTypeComboBox" Grid.Column="2"
                                          ItemsSource="{x:Bind ViewModel.SourceTypeOptions, Mode=OneWay}"
                                          SelectedIndex="{x:Bind ViewModel.SelectedSourceTypeValue, Mode=TwoWay}"
                                          IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}" />
                                <ComboBox x:Uid="WinGetSourceTrustComboBox" Grid.Column="3"
                                          ItemsSource="{x:Bind ViewModel.SourceTrustLevelOptions, Mode=OneWay}"
                                          SelectedIndex="{x:Bind ViewModel.SelectedSourceTrustLevelValue, Mode=TwoWay}"
                                          IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}" />
                                <Button x:Uid="WinGetAddSourceButton" Grid.Column="4"
                                            VerticalAlignment="Bottom"
                                            IsEnabled="{x:Bind ViewModel.IsAddSourceButtonEnabled, Mode=OneWay}"
                                            Click="{x:Bind ViewModel.AddSourceAsync}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button x:Uid="WinGetCancelButton" Grid.Column="5"
                                            VerticalAlignment="Bottom"
                                            IsEnabled="{x:Bind ViewModel.IsSourceOperationCancelButtonEnabled, Mode=OneWay}"
                                            Click="{x:Bind ViewModel.CancelCurrentSourceOperation}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                            </Grid>
                        </Border>
                        <toolkits:WrapPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            HorizontalSpacing="8"
                                            VerticalSpacing="8">
                            <Button x:Uid="WinGetRefreshSourcesButton"
                                    IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}"
                                    Click="{x:Bind ViewModel.LoadSourcesCore}">
                                <Button.ContentTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                                            <TextBlock Text="{x:Bind}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                            <Button x:Uid="WinGetSourcesBulkActionsButton" MinWidth="36"
                                    MinHeight="36"
                                    Padding="6"
                                    IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}">
                                <FontIcon Glyph="&#xE712;" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="WinGetUpdateSelectedSourcesMenuFlyoutItem"
                                                        Click="{x:Bind ViewModel.UpdateSelectedSources_Click}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xECC5;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Uid="WinGetRemoveSelectedSourcesMenuFlyoutItem"
                                                        Click="{x:Bind ViewModel.RemoveSelectedSources_Click}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button x:Uid="WinGetSelectAllSourcesButton" MinWidth="36"
                                    MinHeight="36"
                                    Padding="6"
                                    IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}"
                                    Click="{x:Bind ViewModel.SelectAllSources_Click}">
                                <SymbolIcon Symbol="SelectAll" />
                            </Button>
                            <Button x:Uid="WinGetDeselectAllSourcesButton" MinWidth="36"
                                    MinHeight="36"
                                    Padding="6"
                                    IsEnabled="{x:Bind ViewModel.SourcesUIElementsAreEnabled, Mode=OneWay}"
                                    Click="{x:Bind ViewModel.DeselectAllSources_Click}">
                                <FontIcon Glyph="&#xE8E6;" />
                            </Button>
                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="12"
                                    Padding="12,8">
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <Run Text="Items: " />
                                    <Run Text="{x:Bind ViewModel.SourcesCount, Mode=OneWay}" />
                                    <Run Text=" | Selected: " />
                                    <Run Text="{x:Bind ViewModel.SelectedSourcesCount, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                        </toolkits:WrapPanel>
                        <customUI:ListViewV2 Grid.Row="2"
                                             RegistryKey="WinGet_Sources"
                                             ItemsSource="{x:Bind ViewModel.Sources, Mode=OneWay}"
                                             SelectionMode="Multiple"
                                             SelectionChanged="{x:Bind ViewModel.SourcesListView_SelectionChanged}"
                                             ScrollViewer.HorizontalScrollMode="Disabled"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <customUI:ListViewV2.ItemTemplate>
                                <DataTemplate x:DataType="vm:WinGetSourceInfo">
                                    <Border Padding="16"
                                            Margin="4,2,4,10"
                                            CornerRadius="10"
                                            BorderThickness="1"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            HorizontalAlignment="Stretch">
                                        <Grid RowSpacing="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                                <TextBlock Text="{x:Bind Type, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" ColumnSpacing="16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock x:Uid="WinGetArgumentTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind Argument, Mode=OneWay}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock x:Uid="WinGetOriginTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind Origin, Mode=OneWay}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Spacing="2">
                                                    <TextBlock x:Uid="WinGetTrustTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind TrustLevel, Mode=OneWay}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid Grid.Row="2" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button x:Uid="WinGetUpdateSourceButton" Grid.Column="0"
                                                        IsEnabled="{x:Bind IsActionEnabled, Mode=OneWay}"
                                                        Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.UpdateSource_Click}">
                                                    <Button.ContentTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xECC5;" FontSize="16"/>
                                                                <TextBlock Text="{x:Bind}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                                <Button x:Uid="WinGetRemoveSourceButton" Grid.Column="1"
                                                        IsEnabled="{x:Bind IsActionEnabled, Mode=OneWay}"
                                                        Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.RemoveSource_Click}">
                                                    <Button.ContentTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                                                <TextBlock Text="{x:Bind}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                                <Button x:Uid="WinGetCancelButton" Grid.Column="2"
                                                        IsEnabled="{x:Bind IsOperationCancellationAvailable, Mode=OneWay}"
                                                        Visibility="{x:Bind OperationCancelButtonVisibility, Mode=OneWay}"
                                                        Click="{x:Bind viewModels:ViewModelProvider.WinGetManagementVM.CancelSourceOperation_Click}">
                                                    <Button.ContentTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                                                <TextBlock Text="{x:Bind}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                                <TextBlock Grid.Column="3"
                                                           Text="{x:Bind Status, Mode=OneWay}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Style="{ThemeResource CaptionTextBlockStyle}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </customUI:ListViewV2.ItemTemplate>
                        </customUI:ListViewV2>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>
