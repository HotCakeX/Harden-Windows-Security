<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AppControlManager.Pages.ComparePolicies"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:customUI="using:AppControlManager.CustomUIElements"
      xmlns:CCToolKit="using:CommonCore.ToolKits"
      xmlns:vm="using:AppControlManager.ViewModels"
      xmlns:animatedvisuals="using:AnimatedVisuals"
      FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">
    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <customUI:InfoBarV2 Grid.Row="0"
                            IsOpen="{x:Bind ViewModel.MainInfoBar.IsOpen, Mode=TwoWay}"
                            IsClosable="{x:Bind ViewModel.MainInfoBar.IsClosable, Mode=OneWay}"
                            Message="{x:Bind ViewModel.MainInfoBar.Message, Mode=OneWay}"
                            Severity="{x:Bind ViewModel.MainInfoBar.Severity, Mode=OneWay}"
                            Title="{x:Bind ViewModel.MainInfoBar.Title, Mode=OneWay}"/>
        <CCToolKit:WrapPanel Grid.Row="1"
                             HorizontalAlignment="Center"
                             HorizontalSpacing="15"
                             VerticalSpacing="10">
            <ProgressRing IsIndeterminate="True"
                          Visibility="{x:Bind ViewModel.ProgressRingVisibility, Mode=OneWay}"
                          Margin="0,0,5,0"/>
            <customUI:ButtonV2 x:Uid="ComparePoliciesFirstBrowseButton"
                               x:Name="FirstPolicyBrowseButton"
                               IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                               ObservedData="{x:Bind ViewModel.FirstPolicy.PolicyIdentifier, Mode=OneWay, FallbackValue=''}"
                               Click="{x:Bind ViewModel.BrowseForFirstPolicy}">
                <customUI:ButtonV2.ContentTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <AnimatedIcon Visibility="{x:Bind vm:ViewModelProvider.ComparePoliciesVM.FirstPolicyLightAnimatedIconVisibility, Mode=OneWay}"
                                          Height="20"
                                          Margin="0,0,5,0"
                                          Width="20">
                                <AnimatedIcon.Source>
                                    <animatedvisuals:Light/>
                                </AnimatedIcon.Source>
                            </AnimatedIcon>
                            <FontIcon Glyph="&#xEC50;" FontSize="16"/>
                            <TextBlock Text="{x:Bind}"/>
                        </StackPanel>
                    </DataTemplate>
                </customUI:ButtonV2.ContentTemplate>
                <customUI:ButtonV2.Flyout>
                    <Flyout x:Name="FirstPolicyBrowseButton_FlyOut">
                        <CCToolKit:WrapPanel Orientation="Vertical"
                                             HorizontalSpacing="15"
                                             VerticalSpacing="15">
                            <Button x:Uid="ClearButton" Click="{x:Bind ViewModel.ClearFirstPolicy}">
                                <Button.ContentTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE894;" FontSize="16"/>
                                            <TextBlock Text="{x:Bind}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                            <TextBlock x:Uid="ViewSelectedFilesTextBlock" TextWrapping="WrapWholeWords"/>
                            <TextBox Text="{x:Bind ViewModel.FirstPolicy.PolicyIdentifier, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     IsSpellCheckEnabled="False"
                                     MinWidth="400"
                                     IsReadOnly="True"/>
                        </CCToolKit:WrapPanel>
                    </Flyout>
                </customUI:ButtonV2.Flyout>
            </customUI:ButtonV2>
            <customUI:ButtonV2 x:Uid="ComparePoliciesSecondBrowseButton"
                               x:Name="SecondPolicyBrowseButton"
                               IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                               ObservedData="{x:Bind ViewModel.SecondPolicy.PolicyIdentifier, Mode=OneWay, FallbackValue=''}"
                               Click="{x:Bind ViewModel.BrowseForSecondPolicy}">
                <customUI:ButtonV2.ContentTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <AnimatedIcon Visibility="{x:Bind vm:ViewModelProvider.ComparePoliciesVM.SecondPolicyLightAnimatedIconVisibility, Mode=OneWay}"
                                          Height="20"
                                          Margin="0,0,5,0"
                                          Width="20">
                                <AnimatedIcon.Source>
                                    <animatedvisuals:Light/>
                                </AnimatedIcon.Source>
                            </AnimatedIcon>
                            <FontIcon Glyph="&#xEC50;" FontSize="16"/>
                            <TextBlock Text="{x:Bind}"/>
                        </StackPanel>
                    </DataTemplate>
                </customUI:ButtonV2.ContentTemplate>
                <customUI:ButtonV2.Flyout>
                    <Flyout x:Name="SecondPolicyBrowseButton_FlyOut">
                        <CCToolKit:WrapPanel Orientation="Vertical"
                                             HorizontalSpacing="15"
                                             VerticalSpacing="15">
                            <Button x:Uid="ClearButton" Click="{x:Bind ViewModel.ClearSecondPolicy}">
                                <Button.ContentTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE894;" FontSize="16"/>
                                            <TextBlock Text="{x:Bind}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                            <TextBlock x:Uid="ViewSelectedFilesTextBlock" TextWrapping="WrapWholeWords"/>
                            <TextBox Text="{x:Bind ViewModel.SecondPolicy.PolicyIdentifier, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     IsSpellCheckEnabled="False"
                                     MinWidth="400"
                                     IsReadOnly="True"/>
                        </CCToolKit:WrapPanel>
                    </Flyout>
                </customUI:ButtonV2.Flyout>
            </customUI:ButtonV2>
            <Button x:Uid="ComparePoliciesCompareButton"
                    IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                    Click="{x:Bind ViewModel.CompareLogic}">
                <Button.ContentTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8AB;" FontSize="16"/>
                            <TextBlock Text="{x:Bind}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button x:Uid="RefreshButton"
                    Click="{x:Bind ViewModel.CompareLogic}"
                    IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}">
                <Button.ContentTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                            <TextBlock Text="{x:Bind}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                    x:Uid="ExportToJSONButton"
                    Click="{x:Bind ViewModel.ExportResultsToJsonLogic}">
                <Button.ContentTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
                            <TextBlock Text="{x:Bind}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </CCToolKit:WrapPanel>
        <TwoPaneView Grid.Row="2"
                     MinWideModeWidth="1050"
                     MinTallModeHeight="0"
                     Pane1Length="*"
                     Pane2Length="*"
                     PanePriority="Pane1"
                     WideModeConfiguration="LeftRight"
                     TallModeConfiguration="TopBottom">
            <TwoPaneView.Pane1>
                <Border Padding="14"
                        CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Spacing="4">
                            <TextBlock Text="Policy inventory" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <TextBlock Text="Select a section card to preview that entire policy element group. Use the First and Second number chips to include or hide each policy in the preview."
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.7"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <TextBlock Text="Run a comparison to see policy element counts."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.6"
                                       Visibility="{x:Bind ViewModel.InventoryEmptyStateVisibility, Mode=OneWay}"/>
                            <ListView ItemsSource="{x:Bind ViewModel.ElementCounts, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedElementCountItem, Mode=TwoWay}"
                                      SelectionMode="Single"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4,0,4"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PolicyElementCountItem">
                                        <Border Padding="14"
                                                CornerRadius="10"
                                                BorderThickness="1"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="128"/>
                                                    <ColumnDefinition Width="128"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="{x:Bind Section}"
                                                               FontSize="20"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="WrapWholeWords"/>
                                                    <TextBlock Text="{x:Bind Note}"
                                                               TextWrapping="WrapWholeWords"
                                                               Opacity="0.74"/>
                                                    <TextBlock Text="{x:Bind DeltaText}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="WrapWholeWords"/>
                                                </StackPanel>
                                                <ToggleButton Grid.Column="1"
                                                              MinHeight="60"
                                                              MinWidth="100"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch"
                                                              IsChecked="{x:Bind IsFirstEnabled, Mode=TwoWay}">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <TextBlock Text="First" Opacity="0.76"/>
                                                        <Viewbox MaxWidth="96" StretchDirection="DownOnly">
                                                            <TextBlock Text="{x:Bind FirstCount}"
                                                                       FontSize="28"
                                                                       FontWeight="SemiBold"/>
                                                        </Viewbox>
                                                    </StackPanel>
                                                </ToggleButton>
                                                <ToggleButton Grid.Column="2"
                                                              MinHeight="60"
                                                              MinWidth="100"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch"
                                                              IsChecked="{x:Bind IsSecondEnabled, Mode=TwoWay}">
                                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                        <TextBlock Text="Second" Opacity="0.76"/>
                                                        <Viewbox MaxWidth="96" StretchDirection="DownOnly">
                                                            <TextBlock Text="{x:Bind SecondCount}"
                                                                       FontSize="28"
                                                                       FontWeight="SemiBold"/>
                                                        </Viewbox>
                                                    </StackPanel>
                                                </ToggleButton>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </TwoPaneView.Pane1>
            <TwoPaneView.Pane2>
                <Border Padding="14"
                        CornerRadius="10"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0"
                              ColumnSpacing="12"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.RowSpan="2"
                                        Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.PreviewTitle, Mode=OneWay}"
                                           Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.PreviewSubtitle, Mode=OneWay}"
                                           TextWrapping="WrapWholeWords"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <CCToolKit:WrapPanel Grid.Row="0"
                                                 Grid.Column="1"
                                                 HorizontalAlignment="Right"
                                                 HorizontalSpacing="8"
                                                 VerticalSpacing="8">
                                <ComboBox MinWidth="160"
                                          ItemsSource="{x:Bind ViewModel.PreviewSortOptions}"
                                          SelectedItem="{x:Bind ViewModel.SelectedPreviewSortOption, Mode=TwoWay}"/>
                                <Button Content="Sort"
                                        IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                                        Click="{x:Bind ViewModel.ApplyPreviewSortLogic}">
                                    <Button.ContentTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8CB;" FontSize="16"/>
                                                <TextBlock Text="{x:Bind}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                            </CCToolKit:WrapPanel>
                        </Grid>
                        <Grid Grid.Row="1">
                            <TextBlock Text="Select an inventory section on the left to preview the exact items from both policies."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.6"
                                       Visibility="{x:Bind ViewModel.PreviewEmptyStateVisibility, Mode=OneWay}"/>
                            <ListView ItemsSource="{x:Bind ViewModel.PreviewItems, Mode=OneWay}"
                                      SelectionMode="None"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PolicyPreviewItem">
                                        <Border Margin="0,5,0,5"
                                                Padding="14"
                                                CornerRadius="10"
                                                BorderThickness="1"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <StackPanel Spacing="8">
                                                <CCToolKit:WrapPanel HorizontalSpacing="8" VerticalSpacing="6">
                                                    <Border Padding="8,4"
                                                            CornerRadius="10"
                                                            Background="#3374D6"
                                                            Visibility="{x:Bind FirstPolicyLabelVisibility}">
                                                        <TextBlock Text="First policy"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Border Padding="8,4"
                                                            CornerRadius="10"
                                                            Background="#D97000"
                                                            Visibility="{x:Bind SecondPolicyLabelVisibility}">
                                                        <TextBlock Text="Second policy"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                </CCToolKit:WrapPanel>
                                                <TextBlock Text="{x:Bind Title}"
                                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                           TextWrapping="WrapWholeWords"
                                                           IsTextSelectionEnabled="True"/>
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Padding="10"
                                                            CornerRadius="8"
                                                            Background="#1F2E7D55"
                                                            BorderThickness="1"
                                                            BorderBrush="#802E7D55"
                                                            Visibility="{x:Bind SharedDetailsVisibility}">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Shared details" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{x:Bind SharedDetails}"
                                                                       TextWrapping="WrapWholeWords"
                                                                       IsTextSelectionEnabled="True"
                                                                       FontSize="14"
                                                                       LineHeight="22"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Grid.Column="1"
                                                            Padding="10"
                                                            CornerRadius="8"
                                                            Background="#1F8A4E00"
                                                            BorderThickness="1"
                                                            BorderBrush="#808A4E00"
                                                            Visibility="{x:Bind DifferentDetailsVisibility}">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Different details" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{x:Bind DifferentDetails}"
                                                                       TextWrapping="WrapWholeWords"
                                                                       IsTextSelectionEnabled="True"
                                                                       FontSize="14"
                                                                       LineHeight="22"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{x:Bind Details}"
                                                           TextWrapping="WrapWholeWords"
                                                           IsTextSelectionEnabled="True"
                                                           Opacity="0.86"
                                                           Visibility="{x:Bind RawDetailsVisibility}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </TwoPaneView.Pane2>
        </TwoPaneView>
    </Grid>
</Page>
