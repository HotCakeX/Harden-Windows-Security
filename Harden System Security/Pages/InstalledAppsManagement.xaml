<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HardenSystemSecurity.Pages.InstalledAppsManagement"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    xmlns:CC="using:CommonCore.Others"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:xamlData="using:Microsoft.UI.Xaml.Data"
    xmlns:vm="using:HardenSystemSecurity.ViewModels"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}"
    xmlns:animatedvisuals="using:AnimatedVisuals"
    Unloaded="{x:Bind ViewModel.CleanupTransientViewState}">

    <Grid>

        <Grid.Resources>

            <!-- For the Packaged Apps ListView Grouping -->
            <CollectionViewSource x:Name="PackagedAppsCollectionViewSource"
                           Source="{x:Bind ViewModel.AppsListItemsSource, Mode=OneWay}"
                           IsSourceGrouped="True"/>

            <!-- Defines a single App that is displayed in the ListView -->
            <DataTemplate x:Key="PackagedAppsListViewTemplate" x:DataType="CC:PackagedAppView">
                <Border x:Name="ItemBorder"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Margin="4,2"
                        Padding="12,10">

                    <!-- Hover and Selection Visual States -->
                    <Border.BackgroundTransition>
                        <BrushTransition Duration="0:0:0.2"/>
                    </Border.BackgroundTransition>

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal"/>
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="ItemBorder.Background" Value="{ThemeResource LayerFillColorAltBrush}"/>
                                    <Setter Target="ItemBorder.BorderBrush" Value="{ThemeResource AccentFillColorSecondaryBrush}"/>
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Target="ItemBorder.Background" Value="{ThemeResource LayerFillColorAltBrush}"/>
                                    <Setter Target="ItemBorder.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    <Setter Target="AppNameText.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <Grid x:Name="MainBorder" RowSpacing="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.RowSpan="2"
                                Background="{ThemeResource LayerFillColorAltBrush}"
                                CornerRadius="10"
                                Width="52"
                                Height="52"
                                Margin="0,0,12,0"
                                VerticalAlignment="Top">
                            <Image Source="{x:Bind Logo}"
                                   Stretch="UniformToFill"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Grid.Row="0"
                                    Spacing="2"
                                    VerticalAlignment="Top">
                            <TextBlock x:Name="AppNameText"
                                       Text="{x:Bind DisplayName}"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       x:Phase="0"/>
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           x:Uid="PFNPublisherLabel"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Publisher}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           x:Phase="1"/>
                            </Grid>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Grid.Row="0"
                                Style="{ThemeResource AccentButtonStyle}"
                                CornerRadius="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                ToolTipService.ToolTip="Quick Actions">
                            <FontIcon Glyph="&#xE712;" FontSize="16"/>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Uid="UninstallText"
                                                    Icon="Delete"
                                                    Click="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).UninstallSingleApp_Click}"/>
                                    <MenuFlyoutItem x:Uid="RepairAppText"
                                                    Click="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).RepairApp_Click}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE90F;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Uid="ResetAppText"
                                                    Click="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).ResetApp_Click}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE72C;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Uid="TerminateAppText"
                                                    Click="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).TerminateApp_Click}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE71A;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Uid="AddLoopbackExemptionText"
                                                    Icon="Add"
                                                    IsEnabled="{x:Bind CanAddLoopbackExemption, Mode=OneWay}"
                                                    Click="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).AddLoopbackExemption_Click}"/>
                                    <MenuFlyoutItem x:Uid="OpenLocationText"
                                                     Icon="Folder"
                                                     Click="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).OpenAppLocation_Click}"/>
                                    <MenuFlyoutItem x:Uid="CopyAppDetailsText"
                                                     Icon="Copy"
                                                     Click="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).CopyAppDetails_Click}"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <CCToolKit:WrapPanel Grid.Column="1"
                                             Grid.ColumnSpan="2"
                                             Grid.Row="1"
                                             Orientation="Horizontal"
                                             HorizontalSpacing="15"
                                             VerticalSpacing="5">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           x:Uid="PFNVersionLabel"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text=":"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,4,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Version}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           x:Phase="1"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           x:Uid="PFNArchitectureLabel"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text=":"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,4,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Architecture}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           x:Phase="1"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           x:Uid="PFNInstalledDateLabel"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text=":"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,4,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind InstalledDate}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           x:Phase="1"/>
                            </Grid>

                            <Grid>
                               <Grid.ColumnDefinitions>
                                   <ColumnDefinition Width="Auto"/>
                                   <ColumnDefinition Width="Auto"/>
                                   <ColumnDefinition Width="*"/>
                               </Grid.ColumnDefinitions>
                               <TextBlock Grid.Column="0"
                                          x:Uid="PFNLoopbackExemptionLabel"
                                          Style="{ThemeResource CaptionTextBlockStyle}"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                               <TextBlock Grid.Column="1"
                                          Text=":"
                                          Style="{ThemeResource CaptionTextBlockStyle}"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Margin="0,0,4,0"/>
                               <TextBlock Grid.Column="2"
                                          Text="{x:Bind LoopbackExemptionStatus, Mode=OneWay}"
                                          Style="{ThemeResource CaptionTextBlockStyle}"
                                          x:Phase="1"/>
                            </Grid>
                        </CCToolKit:WrapPanel>

                        <Expander x:Name="DetailsExpander"
                                  Grid.ColumnSpan="3"
                                  Grid.Row="2"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  CornerRadius="10"
                                  Background="{ThemeResource LayerFillColorAltBrush}"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  Expanding="{x:Bind ((vm:InstalledAppsManagementVM)VMRef).AppDetailsExpander_Expanding}">
                            <Expander.Header>
                                <TextBlock x:Uid="DetailsText"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </Expander.Header>

                            <StackPanel Spacing="8">
                                <CCToolKit:WrapPanel Orientation="Horizontal"
                                                     HorizontalSpacing="8"
                                                     VerticalSpacing="8">
                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNAppSizeLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind AppSize, Mode=OneWay}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="1"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNAppDataSizeLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind AppDataSize, Mode=OneWay}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="1"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNAppTotalUsageLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind TotalUsage, Mode=OneWay}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="1"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNIsFrameworkLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind IsFramework}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNIsResourcePackageLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind IsResourcePackage}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNIsBundleLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind IsBundle}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNIsDevelopmentModeLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind IsDevelopmentMode}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNNonRemovableLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind NonRemovable}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNIsPartiallyStagedLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind IsPartiallyStaged}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="PFNSignatureKindLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind SignatureKind}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border MinWidth="100"
                                            Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="StatusHeader"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind Status}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="WrapWholeWords"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>
                                </CCToolKit:WrapPanel>

                                <StackPanel Spacing="8">
                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="PFNLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind PackageFamilyName}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="PFNPublisherID"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind PublisherID}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="PFNFullNameLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind FullName}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="PFNInstallLocation"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind InstallLocation}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="PFNDependenciesLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind Dependencies}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <TextBlock x:Uid="PFNCapabilitiesLabel"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <InfoBadge Value="{x:Bind CapabilityCount}"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Capabilities}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="PFNPackageUserInformationLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind PackageUserInformation}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10,8"
                                            CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Uid="PFNDescription"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind Description}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True"
                                                       x:Phase="2"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- Defines each app-name starting letter shown by SemanticZoom's zoomed-out view. -->
            <DataTemplate x:Key="PackagedAppsZoomedOutTemplate" x:DataType="xamlData:ICollectionViewGroup">
                <Button Width="64"
                        Height="64"
                        Margin="4"
                        Padding="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="{x:Bind vm:ViewModelProvider.InstalledAppsManagementVM.PackagedAppsZoomedOutGroup_Click}">
                    <TextBlock Text="{x:Bind vm:InstalledAppsManagementVM.GetPackagedAppsGroupKey(Group), Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </DataTemplate>

        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <customUI:InfoBarV2 Grid.Row="0"
                            IsOpen="{x:Bind ViewModel.MainInfoBar.IsOpen, Mode=TwoWay}"
                            Message="{x:Bind ViewModel.MainInfoBar.Message, Mode=OneWay}"
                            Severity="{x:Bind ViewModel.MainInfoBar.Severity, Mode=OneWay}"
                            IsClosable="{x:Bind ViewModel.MainInfoBar.IsClosable, Mode=OneWay}" />

        <Expander Grid.Row="1" Margin="0,0,0,5" HorizontalAlignment="Stretch">
            <Expander.Header>

                <CCToolKit:WrapPanel Style="{StaticResource UnifiedToolbarStyle}">

                    <ProgressRing Visibility="{x:Bind ViewModel.ProgressBarVisibility,Mode=OneWay}"
                              VerticalAlignment="Center"
                              IsIndeterminate="True" />

                    <TextBox x:Uid="SearchForAppsPlaceHolder"
                         Text="{x:Bind ViewModel.SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                         VerticalAlignment="Center"/>

                    <!-- Total and Filtered Count Display Border -->
                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="6"
                        Padding="12,8"
                        BorderThickness="0">

                        <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold">
                        <Run x:Uid="TotalText"/>
                        <Run Text="{x:Bind ViewModel.TotalItemsCount, Mode=OneWay}"/>
                        <Run Text=" | Displayed: "/>
                        <Run Text="{x:Bind ViewModel.FilteredItemsCount, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                    <Button IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                        VerticalAlignment="Center"
                        Click="{x:Bind ViewModel.RefreshAppsListButton_Click}">

                        <StackPanel Orientation="Horizontal" Spacing="4">

                            <AnimatedIcon Height="18" Width="18">
                                <AnimatedIcon.Source>
                                    <animatedvisuals:MindMap/>
                                </AnimatedIcon.Source>
                            </AnimatedIcon>

                            <TextBlock x:Uid="GetAppsListText"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>

                    <!-- Uninstall Selected Apps Button -->
                    <Button IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                        VerticalAlignment="Center"
                        Click="{x:Bind ViewModel.UninstallSelectedApps_Click}">
                        <StackPanel Orientation="Horizontal" Spacing="4">

                            <AnimatedIcon Height="18" Width="18">
                                <AnimatedIcon.Source>
                                    <animatedvisuals:Caution/>
                                </AnimatedIcon.Source>
                            </AnimatedIcon>

                            <TextBlock x:Uid="UninstallSelectedAppsText"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <DropDownButton x:Uid="ManageSelectionsDropDownButton">

                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem x:Uid="SelectAllMenuFlyoutItem" IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}" Click="{x:Bind ViewModel.SelectAllMenuFlyoutItem_Click}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8B3;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>

                                <MenuFlyoutItem x:Uid="RemoveSelectionsMenuFlyoutItem" IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}" Click="{x:Bind ViewModel.RemoveSelectionsMenuFlyoutItem_Click}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8E6;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>

                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!-- Selected Items Count Badge -->
                    <Border Background="#aa4b6b"
                        CornerRadius="12"
                        Padding="12,8">

                        <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="WhiteSmoke"
                               VerticalAlignment="Center">
                        <Run Text="Selected: "/>
                        <Run Text="{x:Bind ViewModel.SelectedItemsCount, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                </CCToolKit:WrapPanel>

            </Expander.Header>

            <Expander.Content>

                <CCToolKit:WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalSpacing="10" VerticalSpacing="10">

                    <Button x:Uid="ExportToJsonButton" IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}" Click="{x:Bind ViewModel.ExportToJson_Click}">
                        <Button.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                   <Button x:Uid="ManageLoopbackExemptionsButton"
                           IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                           Click="{x:Bind ViewModel.OpenLoopbackExemptionsDialog_Click}">
                       <Button.ContentTemplate>
                           <DataTemplate x:DataType="x:String">
                               <StackPanel Orientation="Horizontal" Spacing="8">
                                   <FontIcon Glyph="&#xE7F5;" FontSize="16"/>
                                   <TextBlock Text="{x:Bind}"/>
                               </StackPanel>
                           </DataTemplate>
                       </Button.ContentTemplate>
                   </Button>

                </CCToolKit:WrapPanel>

            </Expander.Content>
        </Expander>

        <RefreshContainer Grid.Row="2"
                          IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                          RefreshRequested="{x:Bind ViewModel.RefreshAppsListButton_Click}">

            <SemanticZoom IsZoomedInViewActive="{x:Bind ViewModel.IsPackagedAppsZoomedInViewActive, Mode=TwoWay}">
                <SemanticZoom.ZoomedInView>
                    <ListView IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                              ItemsSource="{x:Bind PackagedAppsCollectionViewSource.View, Mode=OneWay}"
                              Loaded="{x:Bind ViewModel.MainListView_Loaded}"
                              SelectionChanged="{x:Bind ViewModel.MainListView_SelectionChanged}"
                              SelectionMode="Multiple"
                              ItemTemplate="{StaticResource PackagedAppsListViewTemplate}">

                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel AreStickyGroupHeadersEnabled="True"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate x:DataType="CC:GroupInfoListForPackagedAppView">
                                        <Button Padding="12,6"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                ToolTipService.ToolTip="Show app groups">
                                            <TextBlock Text="{x:Bind Key}"
                                                       Style="{ThemeResource TitleTextBlockStyle}"
                                                       AutomationProperties.AccessibilityView="Raw"/>
                                        </Button>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>

                    </ListView>
                </SemanticZoom.ZoomedInView>

                <SemanticZoom.ZoomedOutView>
                    <GridView IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                              ItemsSource="{x:Bind PackagedAppsCollectionViewSource.View.CollectionGroups, Mode=OneWay}"
                              SelectionMode="None"
                              ScrollViewer.VerticalScrollMode="Enabled"
                              ScrollViewer.VerticalScrollBarVisibility="Visible"
                              ItemTemplate="{StaticResource PackagedAppsZoomedOutTemplate}">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal">
                                    <ItemsWrapGrid.ChildrenTransitions>
                                        <TransitionCollection>
                                            <RepositionThemeTransition IsStaggeringEnabled="False"/>
                                        </TransitionCollection>
                                    </ItemsWrapGrid.ChildrenTransitions>
                                </ItemsWrapGrid>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                    </GridView>
                </SemanticZoom.ZoomedOutView>
            </SemanticZoom>

        </RefreshContainer>

    </Grid>
</Page>