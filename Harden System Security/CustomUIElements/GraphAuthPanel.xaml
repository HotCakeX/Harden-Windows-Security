                                           TextTrimming="CharacterEllipsis"/>
                                <Border Padding="8,2"
                                        CornerRadius="10"
                                        Visibility="{x:Bind ActiveAccountBadgeVisibility, Mode=OneWay}"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock x:Uid="ActiveAccountBadgeTextBlock"
                                               FontSize="11"
