                                <Button Grid.Row="0"
                                        Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        x:Uid="CopyAccountMetadataButton"
                                        Click="{x:Bind CopyEnvironment}">
