<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AppControlManager.Pages.GetSecurePolicySettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:CCToolKit="using:CommonCore.ToolKits"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">

    <ScrollViewer>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,10,0,10" Style="{StaticResource GridCardStyle}" Padding="8,15,8,15">

                <CCToolKit:WrapPanel HorizontalSpacing="10" VerticalSpacing="10" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1">

                    <Button x:Uid="RetrieveSecureSettingsButton" Click="{x:Bind ViewModel.InvokeButton_Click}" Margin="0,12,5,0"
                            HorizontalAlignment="Center" Style="{StaticResource AccentButtonStyle}">
                        <Button.ContentTemplate>
                            <DataTemplate x:DataType="x:String">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE9F5;" FontSize="16"/>
                                    <TextBlock Text="{x:Bind}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!-- Input Fields -->
                    <TextBox Text="{x:Bind ViewModel.Provider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             x:Uid="SecureSettingProviderTextBox"
                             MinWidth="200"/>
                    <TextBox Text="{x:Bind ViewModel.Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             x:Uid="SecureSettingKeyTextBox"
                             MinWidth="200"/>
                    <TextBox Text="{x:Bind ViewModel.ValueName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             x:Uid="SecureSettingValueNameTextBox"
                             MinWidth="200"/>

                </CCToolKit:WrapPanel>

            </Border>

            <CCToolKit:WrapPanel HorizontalSpacing="10" Margin="0,15,0,15"
                                VerticalSpacing="10" Orientation="Vertical" HorizontalAlignment="Center" Grid.Row="1">

                <!-- Result Fields -->
                <TextBlock x:Uid="SecureSettingResultsTextBlock" FontWeight="Bold" />
                <TextBox Text="{x:Bind ViewModel.Value, Mode=OneWay}" IsReadOnly="True" Header="Value" MinWidth="200" />
                <TextBox Text="{x:Bind ViewModel.ValueType, Mode=OneWay}" IsReadOnly="True" Header="Value Type" MinWidth="200"/>
                <TextBox Text="{x:Bind ViewModel.ValueSize, Mode=OneWay}" IsReadOnly="True" Header="Value Size" MinWidth="200"/>
                <TextBox Text="{x:Bind ViewModel.Status, Mode=OneWay}" IsReadOnly="True" Header="Status" MinWidth="200"/>
                <TextBox Text="{x:Bind ViewModel.StatusCode, Mode=OneWay}" IsReadOnly="True" Header="Status Code" MinWidth="200"/>

            </CCToolKit:WrapPanel>

            <customUI:InfoBarV2 IsOpen="{x:Bind ViewModel.MainInfoBar.IsOpen, Mode=TwoWay}"
                                Message="{x:Bind ViewModel.MainInfoBar.Message, Mode=OneWay}"
                                Severity="{x:Bind ViewModel.MainInfoBar.Severity, Mode=OneWay}"
                                IsClosable="{x:Bind ViewModel.MainInfoBar.IsClosable, Mode=OneWay}"
                                Margin="0,20,0,0"
                                Grid.Row="2"/>

        </Grid>
    </ScrollViewer>
</Page>
