<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HardenSystemSecurity.Pages.UpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customUI="using:AppControlManager.CustomUIElements"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    FlowDirection="{x:Bind ViewModel.AppSettings.ApplicationGlobalFlowDirection, Mode=OneWay}">

    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <customUI:InfoBarV2 IsOpen="{x:Bind ViewModel.MainInfoBarIsOpen, Mode=TwoWay}"
                                Message="{x:Bind ViewModel.MainInfoBarMessage, Mode=OneWay}"
                                Severity="{x:Bind ViewModel.MainInfoBarSeverity, Mode=OneWay}"
                                IsIconVisible="True"
                                IsClosable="{x:Bind ViewModel.MainInfoBarIsClosable, Mode=OneWay}"
                                x:Uid="UpdatePageUpdateStatusInfoBar"
                                Grid.Row="0">
                <customUI:InfoBarV2.ActionButton>
                    <HyperlinkButton x:Uid="UpdatePageMoreInfoHyperLinkButton"
                                     NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security/wiki/Harden-System-Security" />
                </customUI:InfoBarV2.ActionButton>
            </customUI:InfoBarV2>

            <customUI:InfoBarV2 Grid.Row="1"
                                x:Uid="UpdatePageWhatsNewInfoBar"
                                IsOpen="{x:Bind ViewModel.WhatsNewInfoBarIsOpen, Mode=TwoWay}"
                                Severity="Success"
                                IsClosable="True">
                <customUI:InfoBarV2.IconSource>
                    <FontIconSource Glyph="&#xE8A7;"/>
                </customUI:InfoBarV2.IconSource>
                <customUI:InfoBarV2.ActionButton>
                    <HyperlinkButton x:Uid="UpdatePageSeeWhatsNewHyperLinkButton"
                                     NavigateUri="https://github.com/HotCakeX/Harden-Windows-Security/releases"
                                     HorizontalAlignment="Right"/>
                </customUI:InfoBarV2.ActionButton>
            </customUI:InfoBarV2>

            <StackPanel HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}"
                        Grid.Row="2">

                <win:StackPanel.ChildrenTransitions>
                    <win:EntranceThemeTransition FromVerticalOffset="50" />
                    <win:RepositionThemeTransition IsStaggeringEnabled="False" />
                </win:StackPanel.ChildrenTransitions>

                <customUI:SettingsCardV2 x:Uid="CheckForUpdateSettingsCard"
                                         IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}">
                    <customUI:SettingsCardV2.HeaderIcon>
                        <FontIcon Glyph="&#xF83E;"/>
                    </customUI:SettingsCardV2.HeaderIcon>

                    <controls:WrapPanel Orientation="Horizontal">

                        <ProgressRing Visibility="{x:Bind ViewModel.ProgressBarVisibility, Mode=OneWay}"
                                      Value="{x:Bind ViewModel.ProgressBarValue, Mode=OneWay}"
                                      IsIndeterminate="{x:Bind ViewModel.ProgressBarIsIndeterminate, Mode=OneWay}"
                                      Minimum="0"
                                      Maximum="100"
                                      Margin="5,5,15,5"/>

                        <Button IsEnabled="{x:Bind ViewModel.ElementsAreEnabled, Mode=OneWay}"
                                Content="{x:Bind ViewModel.UpdateButtonContent, Mode=OneWay}"
                                x:Uid="UpdatePageCheckForUpdateButton"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="{x:Bind ViewModel.CheckForUpdateButton_Click}"
                                Margin="0,0,15,0">
                            <Button.ContentTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xEDE4;" FontSize="16"/>
                                        <TextBlock Text="{x:Bind}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                    </controls:WrapPanel>

                </customUI:SettingsCardV2>

                <customUI:SettingsCardV2 x:Uid="AutoUpdateCheckSettingsCard">
                    <customUI:SettingsCardV2.HeaderIcon>
                        <FontIcon Glyph="&#xE774;"/>
                    </customUI:SettingsCardV2.HeaderIcon>

                    <ToggleSwitch IsOn="{x:Bind ViewModel.AppSettings.AutoCheckForUpdateAtStartup, Mode=TwoWay}"
                                  x:Uid="ToggleSwitchGeneral"/>
                </customUI:SettingsCardV2>

                <controls:SettingsCard Click="{x:Bind ViewModel.LaunchRating}"
                                       Visibility="{x:Bind ViewModel.RatingsSectionVisibility, Mode=OneWay}"
                                       x:Uid="RateAndReviewSettingsCard"
                                       IsClickEnabled="True"
                                       IsActionIconVisible="True">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEC24;"/>
                    </controls:SettingsCard.HeaderIcon>
                    <controls:SettingsCard.ActionIcon>
                        <FontIcon Glyph="&#xE8A7;"/>
                    </controls:SettingsCard.ActionIcon>
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="InstallAppPackagesSettingsCard"
                                       IsClickEnabled="True"
                                       IsActionIconVisible="True"
                                       Click="{x:Bind ViewModel.NavigateToAppPackageInstallerPage_Click}">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE83B;"/>
                    </controls:SettingsCard.HeaderIcon>
                </controls:SettingsCard>

            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>
